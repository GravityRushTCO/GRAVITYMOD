  // --- ESP TICK GLOBAL DÉSACTIVÉ ---
  // L'ancien hook sur HudMapPlayerWorldPositionSyncSystem.OnUpdate (0x23C4AB4)
  // faisait laguer le jeu : ce système est probablement appelé plusieurs fois
  // par frame ou ré-entrant, et chaque appel déclenchait un Esp_FrameTick
  // (scan + projection + lock mutex). Résultat : le jeu freeze.
  // On revient au tick unique via hook_PreSimulationUpdate (PED uniquement,
  // donc pas de tick en voiture mais pas de bug non plus). Si on veut un tick
  // en voiture plus tard il faut hooker un système qui tick à 60Hz STRICT.
  // int rcEsp = DobbyHook((void *)(B + 0x23C4AB4),
  //                       (dobby_dummy_func_t)hook_HudMapTick,
  //                       (dobby_dummy_func_t *)&orig_HudMapTick);
  // LOGI(DBG ": ESP global tick hook (HudMapPlayerWorldPositionSync)=%d", rcEsp);
  // Les patches statiques patch_NoCollider* ne sont plus utilises (case 109 utilise g_NoClipEnabled).
  // Variables laissees declarees pour eviter d'autres modifications mais non initialisees.


  // --- ANTI-CHEAT (toujours actif) ---
  // ATTENTION : patch_AC = 0x20490B8 est UN TRAMPOLINE IL2CPP PARTAGÉ par
  // 1678 fonctions différentes (vérifié via dump). Le patcher casse une
  // myriade de fonctions dans le jeu, dont la chaîne de damage. INVALIDÉ.
  // V162 AUDIT REMOVED: 6 patches AC* ciblaient des fonctions sans rapport avec
  // un anti-cheat :
  //  - 0x20490B8 = UnityEngine.Purchasing.INativeAppleStore.InterceptPromotionalPurchases (Apple Store, trampoline partagé)
  //  - 0x363ADCC + 0x36558C8 = DigitalOpus MeshBaker.CheckIntegrity (plugin de batching mesh, pas anti-cheat)
  //  - 0x36ED3C0 + 0x3721580 = Mono.Security.Cryptography.DSAManaged.VerifySignature (crypto runtime Mono, dangereux)
  //  - 0x3729D64 = à vérifier mais probablement idem
  // patch_AC = MemoryPatch::createWithHex(B + 0x20490B8, RET1);
  // patch_AC2 = MemoryPatch::createWithHex(B + 0x363ADCC, RET1);
  // patch_AC3 = MemoryPatch::createWithHex(B + 0x36558C8, RET1);
  // patch_AC_Sig1 = MemoryPatch::createWithHex(B + 0x36ED3C0, RET1);
  // patch_AC_Sig2 = MemoryPatch::createWithHex(B + 0x3721580, RET1);
  // patch_AC_Hash = MemoryPatch::createWithHex(B + 0x3729D64, RET1);

  // --- ANTI-BAN (bloque spectate et tracking admin) ---
  // V162 AUDIT REMOVED: patch_AntiBan1 @ 0x2503E58 (cible non identifiée, auto-confessé comme suspect dans les commentaires V151).
  // patch_AntiBan1 = MemoryPatch::createWithHex(B + 0x2503E58, RET);
  patch_AntiBan2 = MemoryPatch::createWithHex(B + 0x2B77E10, RET);  // FreeCamUiTrackPlayerDimension.OnUpdate (vérifié OK)
  // --- DAMAGE DEBUG MINIMAL V151 ---
  // L'utilisateur rapporte : "j'aimbot sur un ped, je vois l'impact de la
  // balle (sang/effet local), mais le ped ne meurt pas / aucun HP perdu".
  // Conclusion : le hit est correctement émis client-side (raycast OK), mais
  // le serveur ne valide pas le damage. Suspects : un des ~40 patches
  // auto-appliqués au boot interfère avec la chaîne damage serveur.
  //
  // MODE DEBUG : on désactive TOUS les auto-applies non-essentiels au boot.
  // Sont retirés cette fois :
  //   - 5 patches AC (signing/hash, peuvent invalider le packet damage)
  //   - 2 patches AntiBan (bloc dupliqué + bloc anti-spectateur)
  //   - 30 patches Admin (GetLevel=6, HasRights, SyncBlock, Kick, Ban, etc.)
  //   - patch_AccessLevel (alias de GetLevel, niveau 6)
  //   - patch_AdminIcon (RET1 sur fonction de check admin)
  //
  // SONT GARDÉS (utiles & probablement non-damage-blocking) :
  //   - patch_Teleport1-7 (utilisés par Teleport_ToPosition pour bypass server)
  //   - patch_NoRecoil (visuel local pur)
  //   - patch_Handcuff1/2 + Jail1/JailTimer (anti-arrest, hors chaîne damage)
  //   - tous les hooks Dobby (NoClip, ESP, FireOnPreCull, DeviceFaker)
  //
  // PROCÉDURE :
  //   1. Build & test : aimbot sur ped, vérifier si HP descend.
  //   2a. Si DAMAGE OK → un des patches retirés bloquait (binary search).
  //   2b. Si DAMAGE TOUJOURS KO → cause ailleurs (hook, Esp_GetBestTargetWorld,
  //       direction redirect, ou patche dans Esp.cpp/Aimbot.cpp).
  LOGI(DBG ": V151 DAMAGE DEBUG — AC/AntiBan/Admin auto-apply DÉSACTIVÉS.");

  // --- V153 FINAL : root cause damage = NoClip, PAS AttackNotAllowed ---
  // On peut donc ré-auto-applier AttackNotAllowed pour le GreenZone bypass.
  // 0x2ACD8E8 = WeaponAttackNotAllowedSyncSystem.OnUpdate → RET
  if (patch_AttackNotAllowed.isValid()) {
    patch_AttackNotAllowed.Modify();
    LOGI(DBG ": V153 AttackNotAllowed ON (auto, GreenZone bypass).");
  }
  // V155 ANNULÉ : WeaponAttackNotAllowed n'est inclus QUE par
  // WeaponProduceAttackMeleeSystem (vérifié dans Assembly-CSharp). Il ne
  // bloque PAS les attaques ranged. Patcher AttackNotAllowedDatagram.Read
  // n'aurait aucun effet sur le bug "1ère balle touche, suivantes ratent".
  // Voir Aimbot.cpp pour les fixes réels (Seed=0, target freshness, log).
  // --- TÉLÉPORT ANTI-CHEAT BYPASS : AUTO-APPLIQUÉ (V158) ---
  // Rétabli car sinon le serveur détecte l'Auto-Follow au bout de 10s et
  // téléporte le joueur dans l'eau (0,0,0) comme punition pour "vol stationnaire".
  patch_Teleport1.Modify();
  patch_Teleport2.Modify();
  patch_Teleport3.Modify();
  patch_Teleport4.Modify();
  patch_Teleport5.Modify();
  patch_Teleport6.Modify();
  patch_Teleport7.Modify();
  LOGI(DBG ": Teleport Anti-Cheat Bypass ON (auto, empêche tp serveur dans l'eau).");

  // --- AMMO AUTO-APPLY (audit) ---
  // RETIRÉS de l'auto-apply (cassent les munitions) :
  //  - patch_InfAmmoInv (PedWeaponAmmoRemoveSystem) : retire l'ammo de
  //    l'inventaire LOCAL en réaction au sync serveur. Bloquer = désync.
  //  - patch_InfAmmoSync (PedWeaponRemoveAmmoSyncSystem) : sync serveur→client.
  //    Bloquer = on ignore les updates ammo du serveur → tirs rejetés.
  //  - patch_InfAmmoSync2 : doublon (CallUpdate de InfAmmoInv).
  //  - patch_InfAmmoSync3 : RIEN À VOIR (PedWeaponDestroySystem, drop arme).
  // Auto-applique seulement le NoRecoil (UI locale, sans risque). InfAmmo
  // doit être activé manuellement via toggle 89 par l'utilisateur.
  if (patch_NoRecoil.isValid()) {
    patch_NoRecoil.Modify();
    LOGI(DBG ": NoRecoil ON (auto)");
  }

  // --- ZONE VERTE BYPASS : AUTO-APPLY RETIRÉ ---
  // DIAGNOSTIC (user report "mes balles ne font aucun dégât même sans rien
  // activer") : les 2 patches ci-dessous sont DANS la même plage d'adresses
  // que la chaîne d'attaque d'armes (0x2ACxxxx / 0x2ADxxxx), à seulement
  // quelques centaines d'octets de patch_GhostBullet = WeaponAttackReceive.
  // Le commentaire du patch admettait déjà que "l'ancien offset 0x2ADAC24
  // bloquait AUCUN DÉGÂT n'est appliqué", le nouvel offset 0x2ADB278 n'a
  // jamais été vérifié sur dump : forte probabilité qu'il soit aussi wrong
  // et qu'il bloque WeaponAttackEmit (= mes hits envoyés au serveur).
  //
  // → on NE les applique plus au boot. Toggle 98 reste disponible pour
  //    l'utilisateur averti qui veut tester la zone verte.
  LOGI(DBG ": GreenZoneBypass NOT auto-applied (protège la damage chain "
           "sortante). Active manuellement via toggle 98 si besoin.");

  // --- SUPER SPEED auto-appliqué (UNIQUEMENT via velocity, pas Animator) ---
  // patch_SuperSpeed (Animator.get_speed → 5.0f) RETIRÉ du démarrage : il
  // accélérait TOUTES les animations dont celles des armes (tir super rapide
  // intempestif). On garde uniquement le hook hook_SetPlanarVelocity qui
  // multiplie la velocity HORIZONTALE du local par g_SpeedMultiplier (slider 143).
  // Résultat : course plus rapide, mais animations d'armes normales.
  // Hook reste prêt mais désactivé tant que slider 143 reste à 10 (vitesse
  // normale). Le case 143 l'active automatiquement dès que l'utilisateur
  // déplace le curseur hors de la valeur neutre.
  g_SuperSpeedEnabled = false;
  LOGI(DBG ": SuperSpeed velocity-hook READY (mult=%.2fx neutre, slider pilote)", g_SpeedMultiplier);

  // --- ADMIN ACCESS SAFE — DÉSACTIVÉ V151 ---
  // patch_AdminIcon @ 0x2973F40 RET1 : suspect d'être en réalité un check
  // "IsAdmin(ped)" qui, RET1, marque TOUS les peds comme admin → le serveur
  // refuse de leur appliquer du damage venant d'un civil.
  // patch_AccessLevel = patch_GetLevel @ 0x297C08C RET6 : pareil, force le
  // niveau admin 6 pour toute query → toute attaque vue comme "civil tape
  // admin" et bloquée par le serveur RP.
  // Les Teleport sont déjà appliqués plus haut (bloc dédié).
  LOGI(DBG ": V151 Admin Icon/AccessLevel DÉSACTIVÉS (suspects damage block).");

  // --- VEHICULE auto-apply COMPLÈTEMENT RETIRÉ ---
  // L'utilisateur a signalé des désynchronisations massives : les joueurs
  // semblaient entrer dans leur voiture puis foncer dans les murs coté client.
  // Cause probable : VehicleNoExtrapolate ET VehicleNoDamage interagissent
  // mal avec la prédiction client/serveur. On laisse les 2 toggles manuels
  // dans le menu pour l'utilisateur avancé, mais OFF par défaut.

  // --- STAMINA INFINIE : RÉINTÉGRÉE EN ARRIÈRE PLAN (V158) ---
  patch_StaminaLose.Modify();
  patch_StaminaRestore.Modify();
  patch_UseStamina.Modify();
  patch_ConsumeStamina.Modify();
  patch_HasStamina.Modify();
  LOGI(DBG ": Stamina infinie auto-appliquée en arrière-plan.");

  // --- NO RELOAD : AUTO-APPLY (V160) ---
  if (patch_NoReload.isValid()) {
    patch_NoReload.Modify();
    LOGI(DBG ": NoReload ON (auto)");
  }

  // --- EMANUEL HACKS INITIALIZATION ---
  patch_NotKo = MemoryPatch::createWithHex(B + 0x0x22C9B84, "20008052C0035FD6"); // IsNotMeleeKnockout -> RET1
  patch_Knockout1 = MemoryPatch::createWithHex(B + 0x2EB64A4, "C0035FD6");       // SetUnconsciousKnockout -> RET
  patch_KoState = MemoryPatch::createWithHex(B + 0x0x22C9B84, "00008052C0035FD6"); // IsMeleeKnockoutState -> RET0
  patch_OnePunch = MemoryPatch::createWithHex(B + 0x22D8E78, "E0FF9F52C0035FD6"); // GetAverageDamage -> MOV W0, 65535; RET

  // NetSniff/IL2CPP-dump retirés du boot (focus = features TP/AutoFarm).
  // Toggle 254/255 et bouton 252 restent fonctionnels si besoin manuel.
  // NetSniff_Install();  // hooks installés mais capture OFF par défaut

  // --- ANTI-ARREST auto-appliqué (toggle 42) ---
  // Le vrai effet est appliqué via la chaîne complète d'anti-arrest qui
  // bascule de nombreux patches. On rejoue la même config que case 42 mais
  // sans passer par TOG (qui dépend de b_PatchesReady, pas encore vrai ici).
  // Listés dans handleAntiArrestStartup() pour clarté.
  // (Implémenté via flag pour appliquer après b_PatchesReady=true.)

  // --- ANTI-SPECTATEUR — DÉSACTIVÉ V151 ---
  // patch_AntiBan1 @ 0x2503E58 RET et patch_AntiBan2 @ 0x2B77E10 RET dans la
  // zone admin/spectate. Sans dump pour vérifier qu'il s'agit vraiment de la
  // fonction spectate (et pas d'un système qui valide les hits ou syncronise
  // l'inventaire), on les retire de l'auto-apply le temps du diagnostic damage.
  LOGI(DBG ": V151 Anti-Spectateur DÉSACTIVÉ (suspect damage block).");

  // --- ANTI-ARREST — DÉSACTIVÉ V152 (diag damage) ---
  // Offsets Handcuff1 @ 0x2A108E4 (proche zone weapon 0x2ACxxxx) et Handcuff2
  // @ 0x28C677C : non vérifiés sur dump. En mode diag on retire tout pour
  // isoler la cause racine du problème damage.
  LOGI(DBG ": V152 Anti-Arrest auto-apply DÉSACTIVÉ (diag damage).");

  // --- GOD MODE : AUCUN auto-apply ---
  // Les patches UI mort (DeathUI1/2/3 + HudDeathCreate/Init/Watch) NE SONT PLUS
  // auto-appliqués au boot car ils empêchent l'écran "Vous êtes mort" et le
  // bouton respawn de s'afficher quand god mode est OFF (tu meurs et tu es
  // bloqué). Ces patches sont maintenant appliqués UNIQUEMENT via le toggle
  // god mode (case 13). Quand god mode est OFF → mort/respawn fonctionnent
  // normalement.
  LOGI(DBG ": Death UI patches NOT auto-applied (mort/respawn fonctionnels par défaut)");

  // --- ESP + AIMBOT INIT ---
  // InstallHooks();
  LOGI(DBG ": ESP/Aimbot hooks installed (skipped at boot)");

  // --- ESP (nouveau module Esp.cpp) ---
  // Esp_Init(B);
  LOGI(DBG ": Esp_Init done (skipped at boot)");

  // --- TELEPORT SLOTS : charge les slots persistés depuis fichier ---
  Teleport_LoadSlots();
  LOGI(DBG ": Teleport slots loaded from /sdcard/Download/onestate_slots.txt");

  // --- ANTI FALL ANIMATION : AUTO-APPLY RETIRÉ (BUG DAMAGE) ---
  //
  // DIAGNOSTIC V145 : user rapporte "je fais aucun dégât aux ennemis, même
  // sans rien activer". Root cause confirmée ici :
  //   patch_FallStateRangeCanEnter @ 0x2F3396C = WeaponRangeFallState.CanEnterState
  //   patch_FallStateMeleeCanEnter @ 0x2F2F030 = OneHandedMeleeWeaponFallState
  //   patch_FallStateCanEnter      @ 0x2F4D748 = état chute générique
  //
  // Ces 3 méthodes sont des state-machine handlers PARTAGÉS PAR TOUS LES PEDS
  // (pas seulement le local). En les forçant à retourner false :
  //   - MON perso ne joue plus l'anim de chute quand il se prend une balle ✓
  //   - MAIS les peds ennemis ne peuvent PLUS entrer dans le RangeFallState
  //     non plus → c'est CE STATE qui (probablement) applique les dégâts /
  //     décrément HP / déclenche la mort → CONCLUSION : zéro damage sortant.
  //
  // Solution : on NE patche plus rien au boot. L'anim de chute est un confort
  // minime ; pouvoir tuer les ennemis est essentiel.
  LOGI(DBG ": Anti-Fall NOT auto-applied (préservation chaîne damage sortante).");

  // --- AIMBOT V153 FINAL : 2 hooks (RayCast + EmitDatagram.Write) ---
  // Root cause damage trouvée = NoClip, donc aimbot peut être réinstallé.
  //   0x2AD5AAC = WeaponStorage.RayCastAttackRanged
  //   0x2ADA8AC = WeaponAttackEmitDatagram.Write (réécrit Direction dans
  //               le datagram pour matcher les hits client → serveur valide)
  // Aimbot_InstallHooks(B);

  // --- DEVICE ID FAKER : hook + GUID initial ---
  // On installe le hook tout de suite (mais inactif tant que toggle 153 OFF).
  // Le GUID est généré au boot et persiste tant que l'utilisateur ne clique
  // pas "Régénérer Device ID" (bouton 154).
  // regenerateFakeDeviceId();
  /* int rcDev = DobbyHook((void*)(B + 0x4249864),
                        (dobby_dummy_func_t)hook_GetDeviceUniqueIdentifier,
                        (dobby_dummy_func_t*)&orig_GetDeviceUniqueIdentifier); */
  /* int rcMdl = DobbyHook((void*)(B + 0x4249904),
                        (dobby_dummy_func_t)hook_GetDeviceModel,
                        (dobby_dummy_func_t*)&orig_GetDeviceModel); */
  /* int rcNam = DobbyHook((void*)(B + 0x42498B4),
                        (dobby_dummy_func_t)hook_GetDeviceName,
                        (dobby_dummy_func_t*)&orig_GetDeviceName); */
  // LOGI(DBG ": DeviceFaker hooks rc=[uid:%d model:%d name:%d] (active=%d id=%s)",
//        rcDev, rcMdl, rcNam, (int)g_DeviceIdFaker, g_FakeDeviceId);

  b_PatchesReady = true;

  // --- Démarrage des threads d'automatisation ---
  // Threads pour TP 10s ennemi, Farm Money, Auto Work, Vol Armée, Meu Destino.
  // Chaque thread tourne en boucle et exécute son action quand le flag global
  // correspondant est activé via le menu.
  startAutomationThreads();

  LOGI(DBG ": V143 CLEAN - AdminLevel4, GodMode, Armes OK");
  return nullptr;
}

extern "C" {
jobjectArray GetFeatureList(JNIEnv *env, jobject context) {
  const char *f[] = {
      // ==========================================================
      // MENU V153 FINAL — Root cause damage = NoClip (IsKinematic
      // sur Rigidbody casse les raycast d'arme côté client).
      // NoClip est gardé MAIS avec avertissement clair : DÉSACTIVAR
      // avant de tirer. Toutes les autres features sont restaurées.
      //
      // AUTO au boot :
      //  - NoRecoil (CameraShake visuel)
      //  - patch_AttackNotAllowed (GreenZone bypass sortant)
      //  - Hooks Aimbot (RayCast + EmitDatagram.Write, gated par flag)
      //  - Hooks NoClip / SuperSpeed / ESP / DeviceFaker (gated par flags)
      // ==========================================================

      // ==========================================================
      // V162.2 — MENU ÉPURÉ (uniquement features 100% fonctionnelles)
      // Toutes les autres features ont été retirées soit parce qu'elles
      // étaient factices (flags jamais lus / patches jamais initialisés),
      // soit parce qu'elles dépendaient de hooks instables qui causaient
      // des crashs (Player Scale hook, MapCheckpointHandler hook).
      // ==========================================================

      // ======= DEFENSE =======
      OBFUSCATE("Category_⚙ SYSTEME"),
      OBFUSCATE("1_Toggle_Activer les Hooks (A FAIRE EN PREMIER)"),

      // ======= TUNING CLUB ONLINE (TCO) =======
      OBFUSCATE("Category_🔥 TCO CHEATS"),
      OBFUSCATE("300_Toggle_Initialiser TCO Hacks"),
      OBFUSCATE("301_InputText_Pseudo de la Cible (Pour Pièges/Mute)"),

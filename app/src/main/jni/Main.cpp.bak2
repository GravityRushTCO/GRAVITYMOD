#define targetLibName "libil2cpp.so"
#define DBG "GRAVITY"

bool b_PatchesReady = false;
uintptr_t g_base = 0;

struct LibInfo {
  uintptr_t image_base = 0;
  bool valid = false;
};

// Utilise dl_iterate_phdr - meme methode que Frida Module.getBaseAddress()
// Evite les faux positifs dans /proc/maps (caches AOT, mmaps, etc.)
struct dl_find_ctx {
  const char *name;
  uintptr_t base;
  bool found;
};
static int dl_find_cb(struct dl_phdr_info *info, size_t, void *data) {
  dl_find_ctx *ctx = (dl_find_ctx *)data;
  if (info->dlpi_name && strstr(info->dlpi_name, ctx->name)) {
    ctx->base = (uintptr_t)info->dlpi_addr;
    ctx->found = true;
    LOGI("GRAVITY: dl_phdr found: %s @ 0x%lx", info->dlpi_name, ctx->base);
    return 1; // stop
  }
  return 0;
}
LibInfo get_lib_info(const char *lib) {
  LibInfo info;
  dl_find_ctx ctx = {lib, 0, false};
  dl_iterate_phdr(dl_find_cb, &ctx);
  if (ctx.found) {
    info.image_base = ctx.base;
    info.valid = true;
  }
  return info;
}
bool wait_for_lib(const char *lib, int secs) {
  char line[512];
  for (int i = 0; i < secs; i++) {
    FILE *fp = fopen("/proc/self/maps", "r");
    if (fp) {
      bool f = false;
      while (fgets(line, sizeof(line), fp)) {
        if (strstr(line, lib)) {
          f = true;
          break;
        }
      }
      fclose(fp);
      if (f) return true;
    }
    sleep(1);
  }
  return false;
}


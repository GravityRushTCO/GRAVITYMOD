      // ======= ESP / AIMBOT =======
      OBFUSCATE("Category_👁 ESP / AIMBOT"),
      OBFUSCATE("120_Toggle_ESP + Aimbot [vise automatiquement les joueurs]"),
      OBFUSCATE("132_Toggle_Wall-Bang [tire à travers les murs]"),
      OBFUSCATE("152_Toggle_Dot Mode [point au centre au lieu des boîtes]"),
      OBFUSCATE("194_Toggle_ESP Ligne"),
      OBFUSCATE("195_Toggle_ESP Box"),
      OBFUSCATE("196_Toggle_ESP Distance"),
      OBFUSCATE("197_Toggle_ESP Marqueur"),
      OBFUSCATE("198_Toggle_ESP Couleur Dynamique"),

      // ======= ARMES =======
      OBFUSCATE("Category_🔫 ARMES"),
      OBFUSCATE("205_Toggle_Pas de Rechargement"),
      OBFUSCATE("206_Toggle_🎯 Aim Bot Tête"),
      OBFUSCATE("207_Toggle_🎯 Aim Bot Torse"),
      OBFUSCATE("208_Toggle_🎯 Silent Aim Tête"),
      OBFUSCATE("209_Toggle_🎯 Silent Aim Torse"),
      OBFUSCATE("210_SeekBar_🎯 Aim FOV (degrés)_30_180"),
      OBFUSCATE("211_Toggle_🎯 Aim Visible Only"),
      OBFUSCATE("212_Toggle_🎯 Visibility Check Outline"),
      OBFUSCATE("213_Toggle_🎯 Visibility Check Shading"),

      // ======= VISION =======
      OBFUSCATE("Category_🎥 VISION"),
      OBFUSCATE("193_SeekBar_Caméra FOV 60 → 140_60_140"),
      OBFUSCATE("214_Button_FOV 80"),
      OBFUSCATE("215_Button_FOV 100"),
      OBFUSCATE("216_Button_FOV 120"),
      OBFUSCATE("217_Button_FOV 140"),

      // ======= MOUVEMENT =======
      // V162.2 RETIRÉ : 191 Fly Hack (ne fonctionne pas correctement).
      OBFUSCATE("Category_⚡ MOUVEMENT"),
      OBFUSCATE("143_SeekBar_Vitesse 1.0x → 3.0x (valeur/10)_10_30"),
      OBFUSCATE("109_Toggle_⚠ NoClip [traverse les murs]"),

      // ======= TÉLÉPORT — Mes Lieux Favoris =======
      // 10 emplacements favoris sauvegardés automatiquement sur le téléphone :
      // tu peux quitter le jeu / rebooter, ils restent là.
      // V162.2 RETIRÉ : catégories HÔPITAUX, COMMISSARIATS, BANQUES, GANGS,
      // MÉTIERS, SHOPS, TAGS — coords hardcodées non vérifiées pour OneState.
      OBFUSCATE("Category_📍 TÉLÉPORT — Mes Lieux Favoris"),
      OBFUSCATE("180_Button_🪝 S'accrocher à la cible (1 fois)"),
      OBFUSCATE("181_Toggle_🛸 Auto-Suivre la cible (vol stationnaire)"),
      OBFUSCATE("160_Button_📌 Mémoriser lieu actuel → Favori 1"),
      OBFUSCATE("170_Button_✈️ Me téléporter au Favori 1"),
      OBFUSCATE("161_Button_📌 Mémoriser lieu actuel → Favori 2"),
      OBFUSCATE("171_Button_✈️ Me téléporter au Favori 2"),
      OBFUSCATE("162_Button_📌 Mémoriser lieu actuel → Favori 3"),
      OBFUSCATE("172_Button_✈️ Me téléporter au Favori 3"),
      OBFUSCATE("163_Button_📌 Mémoriser lieu actuel → Favori 4"),
      OBFUSCATE("173_Button_✈️ Me téléporter au Favori 4"),
      OBFUSCATE("164_Button_📌 Mémoriser lieu actuel → Favori 5"),
      OBFUSCATE("174_Button_✈️ Me téléporter au Favori 5"),
      OBFUSCATE("165_Button_📌 Mémoriser lieu actuel → Favori 6"),
      OBFUSCATE("175_Button_✈️ Me téléporter au Favori 6"),
      OBFUSCATE("166_Button_📌 Mémoriser lieu actuel → Favori 7"),
      OBFUSCATE("176_Button_✈️ Me téléporter au Favori 7"),
      OBFUSCATE("167_Button_📌 Mémoriser lieu actuel → Favori 8"),
      OBFUSCATE("177_Button_✈️ Me téléporter au Favori 8"),
      OBFUSCATE("168_Button_📌 Mémoriser lieu actuel → Favori 9"),
      OBFUSCATE("178_Button_✈️ Me téléporter au Favori 9"),
      OBFUSCATE("169_Button_📌 Mémoriser lieu actuel → Favori 10"),
      OBFUSCATE("179_Button_✈️ Me téléporter au Favori 10"),

      // ======= ADMIN =======
      OBFUSCATE("Category_👑 ADMIN"),
      OBFUSCATE("155_Toggle_Panel Admin [Accès VIP et actions RP]"),

      // ======= ANTI-BAN =======
      OBFUSCATE("Category_🆔 ANTI-BAN"),
      // ⚠ À utiliser UNIQUEMENT en cas de ban : supprime le compte invité actuel
      // et génère une nouvelle identité device → tu repars sur un compte vierge.
      OBFUSCATE("153_Toggle_⚠ Anti-Ban [EN CAS DE BAN UNIQUEMENT — supprime le compte invité actuel]"),
      OBFUSCATE("154_Button_Régénérer Device ID [nouveau GUID + Model + Name]"),
  };
  int n = sizeof(f) / sizeof(f[0]);
  jobjectArray ret = (jobjectArray)env->NewObjectArray(
      n, env->FindClass(OBFUSCATE("java/lang/String")), env->NewStringUTF(""));
  for (int i = 0; i < n; i++)
    env->SetObjectArrayElement(ret, i, env->NewStringUTF(f[i]));
  return ret;
}

#define TOG(p)                                                                 \
  {                                                                            \
    bool v = (p).isValid();                                                    \
    LOGI(DBG ": patch " #p " valid=%d on=%d", v, (int)on);                     \
    if (b_PatchesReady && v) {                                                 \
      bool r = on ? (p).Modify() : (p).Restore();                              \
      LOGI(DBG ": Modify result=%d", r);                                       \
    }                                                                          \
  }


static bool g_HooksApplied = false;
void ApplyBackgroundHooks() {
    if (g_HooksApplied) return;
    g_HooksApplied = true;
    uintptr_t B = g_base;
    if (!B) return;
    fn_GetRigidbodyComponent = (GetRigidbodyComponent_t)(B + 0x31BCA18);
    fn_SetIsKinematic        = (SetIsKinematic_t)(B + 0x31B7BBC);
    DobbyHook((void *)(B + 0x31BF874), (dobby_dummy_func_t)hook_PreSimulationUpdate, (dobby_dummy_func_t *)&orig_PreSimulationUpdate);
    DobbyHook((void *)(B + 0x31AD9BC), (dobby_dummy_func_t)hook_InternalHitFilter, (dobby_dummy_func_t *)&orig_InternalHitFilter);
    DobbyHook((void *)(B + 0x31CA8F4), (dobby_dummy_func_t)hook_SetVelocity, (dobby_dummy_func_t *)&orig_SetVelocity);
    DobbyHook((void *)(B + 0x31CA99C), (dobby_dummy_func_t)hook_SetPlanarVelocity, (dobby_dummy_func_t *)&orig_SetPlanarVelocity);
    DobbyHook((void*)(B + 0x42AA700), (dobby_dummy_func_t)hook_SetFieldOfView, (dobby_dummy_func_t*)&orig_SetFieldOfView);
    DobbyHook((void *)(B + 0x41F61AC), (dobby_dummy_func_t)hook_FireOnPreCull, (dobby_dummy_func_t *)&orig_FireOnPreCull);
    regenerateFakeDeviceId();
    DobbyHook((void*)(B + 0x4249864), (dobby_dummy_func_t)hook_GetDeviceUniqueIdentifier, (dobby_dummy_func_t*)&orig_GetDeviceUniqueIdentifier);
    DobbyHook((void*)(B + 0x4249904), (dobby_dummy_func_t)hook_GetDeviceModel, (dobby_dummy_func_t*)&orig_GetDeviceModel);
    DobbyHook((void*)(B + 0x42498B4), (dobby_dummy_func_t)hook_GetDeviceName, (dobby_dummy_func_t*)&orig_GetDeviceName);
    Aimbot_InstallHooks(B);
    InstallHooks();
    Esp_Init(B);
    LOGI("GRAVITY: All background hooks applied manually via toggle!");
}

void Changes(JNIEnv *env, jclass clazz, jobject obj, jint id, jstring str, jint intVal, jlong longVal,
             jboolean on, jstring str2) {
  LOGI(DBG ": id=%d on=%d ready=%d val=%d", id, (int)on, (int)b_PatchesReady,
       intVal);
  // ============================================================
  // MENU V153 — UNIQUEMENT FONCTIONS SANS INCIDENCE SUR LES TIRS
  // Tous les toggles touchant à la chaîne damage/weapon/attack
  // (god mode, munitions, aimbot, wall-bang, etc.) ont été
  // RETIRÉS car ils cassaient les dégâts sortants.
  // ============================================================
  // ============================================================
  // TCO HACKS
  // ============================================================
  case 300:
    if (on) {
        InitTCOHooks();
    }
    break;
  case 301:
    // Update target pseudo (l'input env->GetStringUTFChars)
    if (str != NULL) {
        const char *val = env->GetStringUTFChars(str, 0);
        input_TargetPseudo = std::string(val);
        env->ReleaseStringUTFChars(str, val);
        LOGI("GRAVITY: Cible TCO définie sur '%s'", input_TargetPseudo.c_str());
    }
    break;
  case 302: SendTrapToTarget(Freezing); break;
  case 303: SendTrapToTarget(Bombardment); break;
  case 304: SendTrapToTarget(CrownDrop); break;
  case 305: SendTrapToTarget(Fist); break;
  
  case 306: feature_ForceField = (bool)on; break;
  case 307: slider_ForceFieldRadius = intVal; break;
  case 308: feature_FlyMode = (bool)on; break;
  case 309: slider_FlyUp = intVal; break;
  case 310: slider_Gravity = intVal; break;
  case 311: ToggleRoomCollisions((bool)on); break;
  case 312: feature_AprilCommands = (bool)on; break;
  case 313: feature_KickMode = (bool)on; break;
  case 314: feature_MaxEconomy = (bool)on; break;

      switch (id) {
    case 1:
      if (on) { ApplyBackgroundHooks(); }
      break;
  // --- GOD MODE (toggle 13) ---
  // ⚠ Compromis assumé : les peds ennemis ne peuvent pas mourir non plus
  // tant que god mode est ON (HealthSync, DeadSync, etc. sont globaux).
  // Désactiver 1 sec pour tirer, réactiver après.
  case 13:
    TOG(patch_Knockout1);       // SetUnconsciousKnockout → RET
    TOG(patch_Knockout2);       // ApplyMeleeKnockoutForce → RET
    TOG(patch_HealthSync);      // ElementHealthSyncSystem → RET
    TOG(patch_DeadSync);        // PedDeadSyncSystem → RET
    TOG(patch_ProcessDead);     // PedProcessDeadSystem → RET
    TOG(patch_PedKill);         // PedKillSystem → RET
    TOG(patch_VehicleNoDamage); // VehicleDamageSystem → RET
    TOG(patch_GhostMelee);      // WeaponAttackMeleeReceiveSystem → RET
    TOG(patch_DeathUI1); TOG(patch_DeathUI2); TOG(patch_DeathUI3);
    TOG(patch_HudDeathCreate); TOG(patch_HudDeathInit); TOG(patch_HudDeathWatch);
    // V154 — God Mode v2 : bloque l'animation KO/mort + l'état unconscious + cleanup melee
    TOG(patch_UnconsciousDetect);    // PedViewHealthUnconsciousDetectSystem
    TOG(patch_MeleeKnockoutCleanup); // MeleeCombatKnockoutCleanupSystem
    TOG(patch_DeadKnockoutRestore);  // PedViewDeadKnockoutRestoreSystem
    TOG(patch_KnockoutSync);         // PedViewKnockoutSystem
    TOG(patch_RagDollState);         // RagDollState.UpdateState
    LOGI(DBG ": GodMode V2 toggle=%d (GhostMelee remis, GhostBullet OFF)", (int)on);
    break;

  // --- MUNITIONS INFINIES (toggle 89) ---
  // patch_AttackEnd RETIRÉ (V144) car bloquait le cycle d'attaque après
  // le 1er tir. Workaround : prendre l'arme AVEC munitions AVANT d'activer.
  case 89:
    TOG(patch_InfAmmo);    // WeaponAmmoDecreaseSystem
    TOG(patch_InfAmmoInv); // PedWeaponAmmoRemoveSystem
    LOGI(DBG ": Munitions Infinies toggle=%d", (int)on);
    break;

  // --- EMANUEL HACKS ---
  case 250:
    TOG(patch_NotKo);
    TOG(patch_Knockout1);
    TOG(patch_KoState);
    LOGI(DBG ": Emanuel Anti-Knockout toggle=%d", (int)on);
    break;

  case 251:
    TOG(patch_OnePunch);
    LOGI(DBG ": Emanuel One Punch toggle=%d", (int)on);
    break;

  // --- IL2CPP DUMP CLASSES (button 252) ---
  // Émet dans logcat la liste des fields (name+offset+type) des classes
  // critiques du jeu (Health, Weapon, Stamina, Economy). À filtrer avec
  // `adb logcat -s EmanuelIL2CPP`. Utiliser une fois en jeu pour identifier
  // les vrais noms des fields privés avant d'implémenter d'autres features
  // reflection-based.
  case 252:
    LOGI(DBG ": 🔬 IL2CPP bootstrap dump requested");
    EmanuelIL2CPP_BootstrapDump();
    break;

  // --- GODMODE REFLECTION (toggle 253) ---
  // Technique Emanuel : pas de byte-patch sur libil2cpp.so. À la place, un
  // thread bg scanne Object.FindObjectsOfTypeAll(ElementHealthSync) et écrit
  // la santé max dans le field "Value" (ou équivalent identifié par 252).
  // Avantage : résiste aux mises à jour du jeu. Inconvénient : risque de
  // désync serveur (même problème que patch_HealthSync statique).
  case 253:
    if (on) {
      EmanuelIL2CPP_StartGodModeReflection();
    } else {
      EmanuelIL2CPP_StopGodModeReflection();
    }
    LOGI(DBG ": 🛡 GodMode Reflection toggle=%d", (int)on);
    break;

  // --- NETSNIFF (toggle 254 + button 255) ---
  // Capture tout le trafic socket (TCP/UDP) et SSL (HTTPS déchiffré) du
  // jeu. Fichier binaire : /data/data/<pkg>/files/netsniff.bin
  // Log lisible    : /data/data/<pkg>/files/netsniff.log
  // Récupération :
  //   adb pull /data/data/com.Chillgaming.oneState/files/netsniff.bin .
  //   adb pull /data/data/com.Chillgaming.oneState/files/netsniff.log .
  // Détection JWT auto : "🔑 JWT detected" dans logcat dès qu'un token
  // passe dans un buffer.
  case 254:
    NetSniff_SetEnabled((bool)on);
    break;
  case 255:
    NetSniff_Flush();
    LOGI(DBG ": 💾 NetSniff flush requested");
    break;

  // --- MONDE : Mode Jour Permanent (Enviro time-of-day) ---
  case 75: TOG(patch_DayMode); break;

  // --- MOUVEMENT : NoClip (CharacterActor IsKinematic) ---
  // ⚠ ROOT CAUSE NO DAMAGE : ce toggle casse les raycast d'arme. Quand ON,
  // tu ne peux PAS faire de dégâts. Toujours désactiver avant de tirer.
  // Hooks Dobby installés au boot ; ce toggle bascule juste le flag global.
  // Quand OFF, on déclenche un burst de 1 sec qui force IsKinematic=false
  // sur tous les peds pour les rendre dynamiques instantanément.
  case 109:
    g_NoClipEnabled = (bool)on;
    if (!on) g_NoClipRestoreUntilMs = noclip_now_ms() + 1000;
    LOGI(DBG ": NoClip enabled=%d", (int)g_NoClipEnabled);
    break;

  // --- ESP + AIMBOT (toggle 120) ---
  case 120:
    Esp_SetEnabled((bool)on);
    Aimbot_SetEnabled((bool)on);
    LOGI(DBG ": ESP+AIMBOT enabled=%d", (int)on);
    break;

  // --- WALL-BANG (toggle 132, indépendant) ---
  // Téléporte l'origine du raycast à 0.5m devant la cible aimbot. Nécessite
  // que toggle 120 soit ON.
  case 132:
    Aimbot_SetWallBang((bool)on);
    LOGI(DBG ": WallBang enabled=%d", (int)on);
    break;

  // --- SLIDER VITESSE (10..30 = 1.0x..3.0x) ---
  // Hook désactivé si curseur à 10 (vitesse normale).
  case 143: {
    int v = intVal;
    if (v < 10) v = 10;
    if (v > 30) v = 30;
    g_SpeedMultiplier = (float)v / 10.0f;
    g_SuperSpeedEnabled = (v != 10);
    LOGI(DBG ": SpeedMultiplier=%.2fx enabled=%d (raw=%d)",
         g_SpeedMultiplier, (int)g_SuperSpeedEnabled, intVal);
    break;
  }

  // --- DOT MODE : ESP point au centre au lieu de box ---
  case 152:
    Esp_SetDotMode((bool)on);
    LOGI(DBG ": DotMode=%d", (int)on);
    break;

  // --- ANTI-BAN : Device ID Faker + Wipe au prochain boot ---
  case 153: {
    g_DeviceIdFaker = (bool)on;
    if (on) {
      regenerateFakeDeviceId();
      scheduleWipeNextBoot();
      LOGI(DBG ": DeviceIdFaker ON id=%s — WIPE programmé au prochain démarrage",
           g_FakeDeviceId);
    } else {
      char flag[512]; getWipeFlagPath(flag, sizeof(flag));
      if (flag[0]) unlink(flag);
      LOGI(DBG ": DeviceIdFaker OFF — wipe pending annulé");
    }
    break;
  }

  // --- BOUTON RÉGÉNÉRER DEVICE ID ---
  case 154:
    regenerateFakeDeviceId();
    LOGI(DBG ": Device ID régénéré = %s (faker actif=%d)",
         g_FakeDeviceId, (int)g_DeviceIdFaker);
    break;

  // --- ADMIN PANEL (toggle 155) ---
  case 155:
    TOG(patch_GetLevel); TOG(patch_HasLevel); TOG(patch_HasRights); TOG(patch_HasRights2);
    TOG(patch_DiplomaPanel); TOG(patch_DiplomaCheck); TOG(patch_DiplomaPenalty); TOG(patch_DiplomaPardon);
    TOG(patch_DiplomaClear); TOG(patch_DiplomaHistory); TOG(patch_DiplomaSync1); TOG(patch_DiplomaSync2);
    TOG(patch_RateAdmin); TOG(patch_FactionSurvey);
    TOG(patch_AdminChatCreate); TOG(patch_AdminChatInitUi); TOG(patch_AdminChatAddMsg); TOG(patch_AdminChatAddSync);
    TOG(patch_AdminChatSendSync); TOG(patch_AdminChatToggle); TOG(patch_AdminChatCloseSync); TOG(patch_AdminChatCreateSync);
    TOG(patch_DiplomaPageResult); TOG(patch_DiplomaCreateSys); TOG(patch_DiplomaInitUiSys); TOG(patch_DiplomaPardonCreate);
    TOG(patch_DiplomaPardonInit); TOG(patch_DiplomaPenaltyCreate); TOG(patch_DiplomaPenaltyInit); TOG(patch_DiplomaResponseSync);
    TOG(patch_RateAdminCreate); TOG(patch_RateAdminInitUi); TOG(patch_RateAdminSend); TOG(patch_RateAdminReason); TOG(patch_RateAdminStars);
    TOG(patch_RemoveRightsH); TOG(patch_ChangeAccessH);
    TOG(patch_AdminIcon);
    TOG(patch_AntiBan1); TOG(patch_AntiBan2);
    LOGI(DBG ": Admin Panel toggle=%d", (int)on);
    break;

  // --- DANCE PARTY (toggle 201) ---
  // Active aussi la gravité réduite (effet "tout le monde flotte / danse").
  // Pour la musique : dropper un fichier MP3 sur le device dans
  //   /sdcard/Download/gravity_dance.mp3
  // Java MediaPlayer le lira automatiquement quand le toggle s'allume (voir
  // EspBridge.dancePartyStart()). Si le fichier n'existe pas, juste l'effet
  // gravité s'applique.
  case 201:
    TOG(patch_LowGravity);
    LOGI(DBG ": DANCE PARTY toggle=%d (musique = /sdcard/Download/gravity_dance.mp3 si dispo)", (int)on);
    break;

  // --- PLAYER SCALE (slider 190) ---
  case 190: {
    int v = intVal;
    if (v < 5) v = 5;
    if (v > 50) v = 50;
    g_PlayerScale = (float)v / 10.0f;
    g_PlayerScaleEnabled = (v != 10);
    LOGI(DBG ": PlayerScale=%.2fx enabled=%d", g_PlayerScale, (int)g_PlayerScaleEnabled);
    break;
  }

  // --- FLY HACK (toggle 191) ---
  case 191:
    g_FlyEnabled = (bool)on;
    TOG(patch_FlyGravity);
    LOGI(DBG ": Fly Hack enabled=%d", (int)g_FlyEnabled);
    break;

  // --- SUPER JUMP (toggle 192) ---
  case 192:
    TOG(patch_SuperJump);
    LOGI(DBG ": Super Jump enabled=%d", (int)on);
    break;

  // --- CAMERA FOV (slider 193) ---
  case 193: {
    int v = intVal;
    if (v < 60) v = 60;
    if (v > 140) v = 140;
    g_CameraFov = (float)v;
    g_CameraFovEnabled = true;
    LOGI(DBG ": CameraFOV=%.0f", g_CameraFov);
    break;
  }

  // --- ESP LINE (toggle 194) ---
  case 194:
    Esp_SetLineEnabled((bool)on);
    LOGI(DBG ": ESP Line=%d", (int)on);
    break;

  // --- ESP BOX (toggle 195) ---
  case 195:
    Esp_SetBoxEnabled((bool)on);
    LOGI(DBG ": ESP Box=%d", (int)on);
    break;

  // --- ESP DISTANCE (toggle 196) ---
  case 196:
    Esp_SetDistanceEnabled((bool)on);
    LOGI(DBG ": ESP Distance=%d", (int)on);
    break;

  // --- ESP MARKER (toggle 197) ---
  case 197:
    Esp_SetMarkerEnabled((bool)on);
    LOGI(DBG ": ESP Marker=%d", (int)on);
    break;

  // --- ESP DYNAMIC COLOR (toggle 198) ---
  case 198:
    Esp_SetDynamicColor((bool)on);
    LOGI(DBG ": ESP DynamicColor=%d", (int)on);
    break;

  // --- VEHICLE WATER DRIVING (toggle 199) ---
  case 199:
    TOG(patch_VehicleWater);
    LOGI(DBG ": Vehicle Water=%d", (int)on);
    break;

  // --- VEHICLE SUPER SPEED (toggle 200) ---
  case 200:
    TOG(patch_VehicleSuperSpeed);
    LOGI(DBG ": Vehicle SuperSpeed=%d", (int)on);
    break;

  // --- BULLET DISTANCE (toggle 202) ---
  case 202:
    g_BulletDistanceEnabled = (bool)on;
    TOG(patch_BulletDist);
    LOGI(DBG ": BulletDistance=%d", (int)on);
    break;

  // --- DAMAGE BOOST (slider 203) ---
  case 203: {
    int v = intVal;
    if (v < 12) v = 12;
    if (v > 30) v = 30;
    g_DamageMultiplier = (float)v / 10.0f;
    g_DamageBoostEnabled = (v != 10);
    LOGI(DBG ": DamageMultiplier=%.2fx enabled=%d", g_DamageMultiplier, (int)g_DamageBoostEnabled);
    break;
  }

  // --- VOITURE INCASSABLE (toggle 204) ---
  case 204:
    TOG(patch_VehicleNoDamage);
    LOGI(DBG ": Vehicle NoDamage=%d", (int)on);
    break;

  // --- PAS DE RECHARGEMENT (toggle 205) ---
  case 205:
    TOG(patch_NoReload);
    LOGI(DBG ": NoReload toggle=%d", (int)on);
    break;

  // --- AIM BOT TÊTE (toggle 206) ---
  case 206:
    if (on) { g_AimBotMode = 1; g_SilentAimMode = 0; }
    else if (g_AimBotMode == 1) g_AimBotMode = 0;
    Aimbot_SetEnabled(g_AimBotMode != 0 || g_SilentAimMode != 0);
    Esp_SetEnabled(g_AimBotMode != 0 || g_SilentAimMode != 0);
    LOGI(DBG ": AimBot Tête=%d", g_AimBotMode);
    break;

  // --- AIM BOT TORSE (toggle 207) ---
  case 207:
    if (on) { g_AimBotMode = 2; g_SilentAimMode = 0; }
    else if (g_AimBotMode == 2) g_AimBotMode = 0;
    Aimbot_SetEnabled(g_AimBotMode != 0 || g_SilentAimMode != 0);
    Esp_SetEnabled(g_AimBotMode != 0 || g_SilentAimMode != 0);
    LOGI(DBG ": AimBot Torse=%d", g_AimBotMode);
    break;

  // --- SILENT AIM TÊTE (toggle 208) ---
  case 208:
    if (on) { g_SilentAimMode = 1; g_AimBotMode = 0; }
    else if (g_SilentAimMode == 1) g_SilentAimMode = 0;
    Aimbot_SetEnabled(g_AimBotMode != 0 || g_SilentAimMode != 0);
    Esp_SetEnabled(g_AimBotMode != 0 || g_SilentAimMode != 0);
    LOGI(DBG ": Silent Aim Tête=%d", g_SilentAimMode);
    break;

  // --- SILENT AIM TORSE (toggle 209) ---
  case 209:
    if (on) { g_SilentAimMode = 2; g_AimBotMode = 0; }
    else if (g_SilentAimMode == 2) g_SilentAimMode = 0;
    Aimbot_SetEnabled(g_AimBotMode != 0 || g_SilentAimMode != 0);
    Esp_SetEnabled(g_AimBotMode != 0 || g_SilentAimMode != 0);
    LOGI(DBG ": Silent Aim Torse=%d", g_SilentAimMode);
    break;

  // --- AIM FOV (slider 210) ---
  case 210: {
    int v = intVal;
    if (v < 30) v = 30;
    if (v > 180) v = 180;
    g_AimFov = (float)v;
    LOGI(DBG ": AimFOV=%.0f", g_AimFov);
    break;
  }

  // --- AIM VISIBLE ONLY (toggle 211) ---
  case 211:
    g_AimVisibleOnly = (bool)on;
    LOGI(DBG ": AimVisibleOnly=%d", (int)on);
    break;

  // --- VISIBILITY CHECK OUTLINE (toggle 212) ---
  case 212:
    g_VisCheckOutline = (bool)on;
    LOGI(DBG ": VisCheckOutline=%d", (int)on);
    break;

  // --- VISIBILITY CHECK SHADING (toggle 213) ---
  case 213:
    g_VisCheckShading = (bool)on;
    LOGI(DBG ": VisCheckShading=%d", (int)on);
    break;

  // --- FOV PRESETS (button 214-217) ---
  case 214: g_CameraFov = 80.0f;  g_CameraFovEnabled = true; LOGI(DBG ": FOV preset = 80"); break;
  case 215: g_CameraFov = 100.0f; g_CameraFovEnabled = true; LOGI(DBG ": FOV preset = 100"); break;
  case 216: g_CameraFov = 120.0f; g_CameraFovEnabled = true; LOGI(DBG ": FOV preset = 120"); break;
  case 217: g_CameraFov = 140.0f; g_CameraFovEnabled = true; LOGI(DBG ": FOV preset = 140"); break;

  // --- WALLHACK VOITURES (toggle 218) ---
  case 218:
    g_VehicleWallhack = (bool)on;
    LOGI(DBG ": Vehicle Wallhack=%d", (int)on);
    break;

  // --- VEHICLE KILL ENEMY (button 219) ---
  case 219: {
    float tx = 0, ty = 0, tz = 0;
    if (Esp_GetBestTargetWorld(&tx, &ty, &tz)) {
      // Téléporte le local sur l'ennemi avec impact (effet "voiture qui tue")
      bool ok = Teleport_ToPosition(tx, ty + 0.5f, tz);
      LOGI(DBG ": 💀 Vehicle Kill → (%.1f, %.1f, %.1f) ok=%d", tx, ty, tz, (int)ok);
    } else {
      LOGI(DBG ": 💀 Vehicle Kill ECHEC : aucune cible");
    }
    break;
  }

  // --- TP VOITURE VERS MARQUEUR (button 220) ---
  // V162 FIX : utilise le waypoint carté (g_LastWaypoint*) au lieu du Slot 1
  // qui n'avait rien à voir avec un marqueur de carte. Quand on est dans une
  // voiture, téléporter le joueur = téléporter la voiture aussi (le ped
  // reste assis dedans). +1.5m en Y pour ne pas spawn sous le sol.
  case 220: {
    if (!g_HasWaypoint) {
      LOGI(DBG ": 🚀 TP Voiture vers Marqueur ECHEC : aucun marqueur posé sur la carte. Pose-en un sur la mini-map d'abord.");
      break;
    }
    bool ok = Teleport_ToPosition(g_LastWaypointX, g_LastWaypointY + 1.5f, g_LastWaypointZ);
    LOGI(DBG ": 🚀 TP Voiture vers Marqueur → (%.1f, %.1f, %.1f) ok=%d",
         g_LastWaypointX, g_LastWaypointY, g_LastWaypointZ, (int)ok);
    break;
  }

  // --- FARM MONEY (toggle 221) ---
  case 221:
    g_FarmMoneyEnabled = (bool)on;
    LOGI(DBG ": Farm Money=%d", (int)on);
    break;

  // --- AUTO WORK / TAXI (toggle 222) ---
  case 222:
    g_AutoWorkEnabled = (bool)on;
    LOGI(DBG ": Auto Work=%d", (int)on);
    break;

  // --- AUTO CLICK (toggle 223) ---
  case 223:
    g_AutoClickEnabled = (bool)on;
    LOGI(DBG ": Auto Click=%d", (int)on);
    break;

  // --- VOL ARMÉE (toggle 224) ---
  case 224:
    g_StealArmyMaterialsEnabled = (bool)on;
    LOGI(DBG ": Steal Army=%d", (int)on);
    break;

  // --- TP ENEMY 10s (toggle 225) ---
  case 225:
    g_TpEnemy10sEnabled = (bool)on;
    LOGI(DBG ": TP Enemy 10s=%d", (int)on);
    break;

  // --- TP POINT DE PÊCHE (button 226) ---
  case 226: {
    // Téléporte au plus proche point de pêche (utilise un offset générique côte)
    bool ok = Teleport_ToPosition(-1700.0f, 0.0f, -1100.0f);
    LOGI(DBG ": 🎣 TP Pêche ok=%d", (int)ok);
    break;
  }

  // --- TP MARQUEUR JOUEUR (button 227) ---
  // Téléporte le joueur au waypoint placé sur la mini-map. Le hook
  // CreateMapGpsCheckpoint.ctor (@ 0x26701F0) capture la position chaque
  // fois que l'utilisateur pose un marqueur → stockée dans
  // g_LastWaypointX/Y/Z + flag g_HasWaypoint.
  case 227: {
    if (!g_HasWaypoint) {
      LOGI(DBG ": 📍 TP Marqueur Joueur ECHEC : aucun marqueur posé sur la carte. "
           "Pose-en un d'abord en cliquant sur la mini-map.");
      break;
    }
    bool ok = Teleport_ToPosition(g_LastWaypointX,
                                  g_LastWaypointY + 1.0f,
                                  g_LastWaypointZ);
    LOGI(DBG ": 📍 TP Marqueur Joueur → (%.1f, %.1f, %.1f) ok=%d",
         g_LastWaypointX, g_LastWaypointY, g_LastWaypointZ, (int)ok);
    break;
  }

  // --- TP MARQUEUR VOITURE (button 228) ---
  // Même cible (waypoint carte) mais petit offset Y pour ne pas spawn
  // sous le sol si on est en voiture (la voiture suit le joueur quand on
  // est assis dedans, donc TP joueur = TP voiture).
  case 228: {
    if (!g_HasWaypoint) {
      LOGI(DBG ": 🚗 TP Marqueur Voiture ECHEC : aucun marqueur posé. "
           "Pose-en un sur la mini-map d'abord.");
      break;
    }
    bool ok = Teleport_ToPosition(g_LastWaypointX,
                                  g_LastWaypointY + 1.5f,
                                  g_LastWaypointZ);
    LOGI(DBG ": 🚗 TP Marqueur Voiture → (%.1f, %.1f, %.1f) ok=%d",
         g_LastWaypointX, g_LastWaypointY, g_LastWaypointZ, (int)ok);
    break;
  }

  // --- TP HÔPITAL (button 229) ---
  case 229: {
    bool ok = Teleport_ToPosition(295.0f, 65.0f, -1450.0f);
    LOGI(DBG ": 🏥 TP Hôpital ok=%d", (int)ok);
    break;
  }

  // --- MEU DESTINO (toggle 230) ---
  case 230:
    g_MeuDestinoEnabled = (bool)on;
    LOGI(DBG ": Meu Destino=%d", (int)on);
    break;

  // --- ENNEMI GÉANT (button 231) ---
  case 231:
    g_PlayerScale = 5.0f;
    g_PlayerScaleEnabled = true;
    LOGI(DBG ": 👹 Ennemi Géant : scale=5x");
    break;

  // --- TAILLE PRESETS (button 232-235) ---
  case 232: g_PlayerScale = 2.0f; g_PlayerScaleEnabled = true; LOGI(DBG ": Taille 2x"); break;
  case 233: g_PlayerScale = 3.0f; g_PlayerScaleEnabled = true; LOGI(DBG ": Taille 3x"); break;
  case 234: g_PlayerScale = 4.0f; g_PlayerScaleEnabled = true; LOGI(DBG ": Taille 4x"); break;
  case 235: g_PlayerScale = 5.0f; g_PlayerScaleEnabled = true; LOGI(DBG ": Taille 5x"); break;

  // --- FOLLOW SPEED (slider 236) ---
  case 236: {
    int v = intVal;
    if (v < 10) v = 10;
    if (v > 100) v = 100;
    g_FollowSpeed = (float)v;
    LOGI(DBG ": Follow Speed=%.1f", g_FollowSpeed);
    break;
  }

  // --- AUTO-CHECKPOINT (toggle 237) ---
  // Force le système QuestStepGoToCheckpointStart à considérer que le joueur
  // est TOUJOURS déjà sur le checkpoint → ProcessEnterCheckpoint est appelé
  // immédiatement, la quête/job/event progresse sans bouger.
  // Comme le mod Malvado : "les checkpoints viennent au joueur".
  case 237:
    TOG(patch_AutoCheckpoint);
    LOGI(DBG ": 🎯 Auto-Checkpoint toggle=%d", (int)on);
    break;

  // --- TELEPORT SLOTS PERSISTANTS (10 slots, sauvés sur disque) ---
  // 160-169 : Save Slot 1-10 / 170-179 : Go Slot 1-10
  case 160: { bool ok = Teleport_SaveSlot(0); LOGI(DBG ": Save Slot 1 ok=%d", (int)ok); break; }
  case 161: { bool ok = Teleport_SaveSlot(1); LOGI(DBG ": Save Slot 2 ok=%d", (int)ok); break; }
  case 162: { bool ok = Teleport_SaveSlot(2); LOGI(DBG ": Save Slot 3 ok=%d", (int)ok); break; }
  case 163: { bool ok = Teleport_SaveSlot(3); LOGI(DBG ": Save Slot 4 ok=%d", (int)ok); break; }
  case 164: { bool ok = Teleport_SaveSlot(4); LOGI(DBG ": Save Slot 5 ok=%d", (int)ok); break; }
  case 165: { bool ok = Teleport_SaveSlot(5); LOGI(DBG ": Save Slot 6 ok=%d", (int)ok); break; }
  case 166: { bool ok = Teleport_SaveSlot(6); LOGI(DBG ": Save Slot 7 ok=%d", (int)ok); break; }
  case 167: { bool ok = Teleport_SaveSlot(7); LOGI(DBG ": Save Slot 8 ok=%d", (int)ok); break; }
  case 168: { bool ok = Teleport_SaveSlot(8); LOGI(DBG ": Save Slot 9 ok=%d", (int)ok); break; }
  case 169: { bool ok = Teleport_SaveSlot(9); LOGI(DBG ": Save Slot 10 ok=%d", (int)ok); break; }
  case 170: { bool ok = Teleport_GoSlot(0); LOGI(DBG ": Go Slot 1 ok=%d", (int)ok); break; }
  case 171: { bool ok = Teleport_GoSlot(1); LOGI(DBG ": Go Slot 2 ok=%d", (int)ok); break; }
  case 172: { bool ok = Teleport_GoSlot(2); LOGI(DBG ": Go Slot 3 ok=%d", (int)ok); break; }
  case 173: { bool ok = Teleport_GoSlot(3); LOGI(DBG ": Go Slot 4 ok=%d", (int)ok); break; }
  case 174: { bool ok = Teleport_GoSlot(4); LOGI(DBG ": Go Slot 5 ok=%d", (int)ok); break; }
  case 175: { bool ok = Teleport_GoSlot(5); LOGI(DBG ": Go Slot 6 ok=%d", (int)ok); break; }
  case 176: { bool ok = Teleport_GoSlot(6); LOGI(DBG ": Go Slot 7 ok=%d", (int)ok); break; }
  case 177: { bool ok = Teleport_GoSlot(7); LOGI(DBG ": Go Slot 8 ok=%d", (int)ok); break; }
  case 178: { bool ok = Teleport_GoSlot(8); LOGI(DBG ": Go Slot 9 ok=%d", (int)ok); break; }
  case 179: { bool ok = Teleport_GoSlot(9); LOGI(DBG ": Go Slot 10 ok=%d", (int)ok); break; }

  // --- GRAPPLER : se téléporter sur la cible aimbot la plus proche ---
  // Récupère la position monde de la meilleure cible (Esp_GetBestTargetWorld)
  // et téléporte le local légèrement au-dessus pour atterrir sur lui.
  case 180: {
    float tx = 0, ty = 0, tz = 0;
    if (Esp_GetBestTargetWorld(&tx, &ty, &tz)) {
      // +1.5m au-dessus de la cible pour ne pas être bloqué par sa capsule.
      bool ok = Teleport_ToPosition(tx, ty + 1.5f, tz);
      LOGI(DBG ": 🪝 Grappler → cible (%.1f, %.1f, %.1f) ok=%d", tx, ty, tz, (int)ok);
    } else {
      LOGI(DBG ": 🪝 Grappler ECHEC : aucune cible visible (active ESP/Aimbot d'abord)");
    }
    break;
  }

  // --- AUTO-FOLLOW TARGET (toggle 181) ---
  // Active le suivi automatique : à 10Hz, téléporte le local 3.5m au-dessus
  // de la cible aimbot (la plus proche du viseur). Tu vises 1s puis tu
  // restes au-dessus d'elle dans les airs, libre de tirer.
  case 181:
    Esp_SetAutoFollow((bool)on);
    LOGI(DBG ": 🛸 Auto-Follow toggle=%d", (int)on);
    break;

  // --- LIEUX STRATÉGIQUES (300-600) ---
  default:
    if (id >= 300 && id <= 600) {
        // Recherche la location dans TeleportData.h
        int catIdx = -1;
        int locIdx = -1;
        
        // Mappage ID -> Catégorie/Location
        if (id >= 300 && id <= 349) { catIdx = 0; locIdx = id - 300; }
        else if (id >= 350 && id <= 399) { catIdx = 1; locIdx = id - 350; }
        else if (id >= 400 && id <= 449) { catIdx = 2; locIdx = id - 400; }
        else if (id >= 450 && id <= 499) { catIdx = 3; locIdx = id - 450; }
        else if (id >= 500 && id <= 549) { catIdx = 4; locIdx = id - 500; }
        else if (id >= 550 && id <= 600) { catIdx = 5; locIdx = id - 550; }

        if (catIdx != -1 && locIdx < g_TPCats[catIdx].count) {
            TPLoc l = g_TPCats[catIdx].locs[locIdx];
            bool ok = Teleport_ToPosition(l.x, l.y, l.z);
            LOGI(DBG ": ✈️ TP Stratégique: %s ok=%d", l.name, (int)ok);
        }
    } else if (id == 601) {
        // TP Prochain Tag
        bool ok = Esp_TeleportToNextGraffiti();
        if (!ok) LOGI(DBG ": 🎨 TP Tag ECHEC (aucun tag chargé aux alentours)");
    } else if (id == 602) {
        Esp_AutoMapGraffiti((bool)on);
        LOGI(DBG ": 🗺️ Auto-Scanner de Tags: %d", (int)on);
    }
    break;
  }
}
}
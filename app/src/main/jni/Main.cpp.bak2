      OBFUSCATE("303_Button_💣 Bombarder la Cible"),
      OBFUSCATE("304_Button_👑 Faire tomber sa Couronne"),
      OBFUSCATE("305_Button_👊 Frapper la Cible"),
      OBFUSCATE("306_Toggle_🛡 Champ de Force (Repousse les autres)"),
      OBFUSCATE("307_SeekBar_📏 Rayon du Champ de Force_10_200"),
      OBFUSCATE("308_Toggle_✈️ Fly Mode"),
      OBFUSCATE("309_SeekBar_✈️ Puissance Fly_0_50"),
      OBFUSCATE("310_SeekBar_🌍 Gravité (10 = normal)_0_50"),
      OBFUSCATE("311_Toggle_🚫 Désactiver Collisions Room"),
      OBFUSCATE("312_Toggle_🤡 April Fools (Tout débloquer)"),
      OBFUSCATE("313_Toggle_👑 Force MasterClient (Kick Mode)"),
      OBFUSCATE("314_Toggle_💰 Max Economy (Bypass EP Limit)"),

      OBFUSCATE("Category_🛡 DEFENSE"),

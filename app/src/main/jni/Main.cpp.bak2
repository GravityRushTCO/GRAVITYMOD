  // --- ESP RENDER-FRAME TICK ---
  // Hook sur Camera.FireOnPreCull @ 0x41F61AC pour synchroniser ESP avec le
  // RENDU Unity (60Hz au lieu du FixedUpdate 50Hz). Avantages :
  //  - Box ESP suivent exactement les positions du jeu (plus de saccades)
  //  - Fonctionne même en voiture (le PreSimulationUpdate local est OFF)
  // Throttle interne dans Esp_FrameTick limite à 60Hz max pour éviter
  // l'appel multiple par frame (1 par caméra rendue).
  /* int rcCam = DobbyHook((void *)(B + 0x41F61AC),
                        (dobby_dummy_func_t)hook_FireOnPreCull,
                        (dobby_dummy_func_t *)&orig_FireOnPreCull); */

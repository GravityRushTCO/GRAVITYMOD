// === NOCLIP via DOBBY HOOKS ============================================
// Approche INSTANTANEE :
// - CharacterActor.PreSimulationUpdate(dt) -> appele CHAQUE FRAME par Unity
//   pour chaque CharacterActor (= peds Lightbug, PAS les voitures).
//   On y force RigidbodyComponent.IsKinematic = true a chaque frame.
//   Quand on desactive : on force kinematic = false pendant ~1s pour restaurer.
// - ColliderComponent3D.InternalHitFilter -> ret false pour traverser les murs.
bool g_NoClipEnabled = false;
static int64_t g_NoClipRestoreUntilMs = 0;

static int64_t noclip_now_ms() {
  struct timespec ts;
  clock_gettime(CLOCK_MONOTONIC, &ts);
  return (int64_t)ts.tv_sec * 1000 + ts.tv_nsec / 1000000;
}

// Pointeurs vers les fonctions IL2CPP appelees depuis le hook.
typedef void *(*GetRigidbodyComponent_t)(void *self);          // 0x31BCA18
static GetRigidbodyComponent_t fn_GetRigidbodyComponent = nullptr;
typedef void (*SetIsKinematic_t)(void *rb, bool value);        // 0x31B7BBC
static SetIsKinematic_t fn_SetIsKinematic = nullptr;

// 1) CharacterActor.PreSimulationUpdate(self, dt) @ 0x31BF874
// Appele CHAQUE FRAME pour chaque CharacterActor (peds Lightbug).
// -> force IsKinematic immediatement = activation/desactivation INSTANTANEES.
typedef void (*PreSimulationUpdate_t)(void *self, float dt);
static PreSimulationUpdate_t orig_PreSimulationUpdate = nullptr;
static void hook_PreSimulationUpdate(void *self, float dt) {
  if (fn_GetRigidbodyComponent && fn_SetIsKinematic) {
    void *rb = fn_GetRigidbodyComponent(self);
    if (rb) {
      if (g_NoClipEnabled || Esp_IsAutoFollowActive()) {
        // V158 FIX "doit réactiver noclip pour rester en l'air" :
        // On force IsKinematic=true pendant l'auto-follow pour bloquer la gravité.
        fn_SetIsKinematic(rb, true);
      } else if (noclip_now_ms() < g_NoClipRestoreUntilMs) {
        fn_SetIsKinematic(rb, false);
      } else {
        fn_SetIsKinematic(rb, false);
      }
    }
  }
  // ESP: register this CharacterActor for the current frame.
  static int _dbgHookCnt = 0;
  if ((_dbgHookCnt++ % 120) == 0) {
    LOGI(DBG ": PreSim hook tick, EspEnabled=%d", (int)Esp_IsEnabled());
  }
  // PreSimulationUpdate n'est appelé QUE pour le local quand il est à pied
  // (remotes désactivés, et le local lui-même est désactivé en voiture).
  // On l'utilise comme tick principal ESP quand on est à pied. En voiture,
  // hook_HudMapTick prend le relais (même thread, donc thread-safe).
  Esp_NotifyLocalActor(self);
  if (Esp_IsEnabled()) Esp_RegisterActor(self);
  orig_PreSimulationUpdate(self, dt);
  if (Esp_IsEnabled()) Esp_FrameTick();
}

// Hook ECS qui tourne SUR LE MAIN THREAD UNITY à chaque frame, indépendamment
// de l'état du local CharacterActor (à pied ou en voiture). C'est le système
// qui sync la position du joueur sur la mini-map, donc il tick en continu.
// On en profite pour faire le Esp_FrameTick : matrices caméra, scan ECS,
// projection world->screen. Tout reste sur le main thread → thread-safe IL2CPP.
//
// HudMapPlayerWorldPositionSyncSystem.OnUpdate @ 0x23C4AB4
typedef void (*HudMapTick_t)(void *self);
static HudMapTick_t orig_HudMapTick = nullptr;
static void hook_HudMapTick(void *self) {
  orig_HudMapTick(self);
  if (Esp_IsEnabled()) Esp_FrameTick();
}

// === Hook Camera.FireOnPreCull @ 0x41F61AC ===
// Cette fonction static Unity est appelée à CHAQUE frame de rendu, juste
// avant que la caméra ne render la scène. C'est le tick idéal pour ESP :
//  - Tourne au framerate du jeu (60Hz typique), pas le FixedUpdate (50Hz)
//  - Tourne TOUJOURS, y compris quand le local est en voiture/avion
//    (contrairement à hook_PreSimulationUpdate qui requiert que le
//     CharacterActor du local soit enabled).
// Signature présumée : void FireOnPreCull(UnityEngine.Camera cam).
typedef void (*FireOnPreCull_t)(void *cam);
static FireOnPreCull_t orig_FireOnPreCull = nullptr;
static void hook_FireOnPreCull(void *cam) {
  orig_FireOnPreCull(cam);
  if (Esp_IsEnabled()) Esp_FrameTick();
}

// --- HOOK CreateMapCheckpointSignalHandler @ 0x251E0F0 ---
// Le ctor CreateMapGpsCheckpoint(Vector3) à 0x26701F0 est inlinable (body
// vide) donc le hook rate. À la place, on hook le HANDLER du signal Morpeh
// qui dispatch le signal — il est appelé de manière non-inlinée via le
// dispatcher de signaux Morpeh. ARM64 ABI : X0=this(HudMapSyncSystem),
// X1=signal(CreateMapGpsCheckpoint*). On lit signal->Point @ offset 0x10
// = 3 floats (x,y,z) en mémoire.
static float g_LastWaypointX = 0.0f, g_LastWaypointY = 0.0f, g_LastWaypointZ = 0.0f;
static bool g_HasWaypoint = false;
typedef void (*MapCheckpointHandler_t)(void* self, void* signal);
static MapCheckpointHandler_t orig_MapCheckpointHandler = nullptr;
static void hook_MapCheckpointHandler(void* self, void* signal) {
  if (signal) {
    float* point = (float*)((uint8_t*)signal + 0x10);
    g_LastWaypointX = point[0];
    g_LastWaypointY = point[1];
    g_LastWaypointZ = point[2];
    g_HasWaypoint = true;
    LOGI(DBG ": 📍 WAYPOINT capté via Morpeh signal handler : (%.2f, %.2f, %.2f)",
         point[0], point[1], point[2]);
  }
  if (orig_MapCheckpointHandler) orig_MapCheckpointHandler(self, signal);
}

// 1bis) CharacterActor.set_Velocity(self, Vector3 value) @ 0x31CA8F4
// C'est le point d'application FINAL de la vitesse composite (Planar+Vertical)
// avant que Lightbug ne la pousse vers le Rigidbody Unity. Multiplier X/Z ici
// fait courir le ped plus vite SANS toucher la gravité (Y conservé).
//
// ARM64 ABI : self dans X0, Vector3 (HFA-3) passé dans S0/S1/S2.
typedef void (*SetVelocity_t)(void *self, float x, float y, float z);
static SetVelocity_t orig_SetVelocity = nullptr;
static int g_SpeedLogCount = 0;

// Fly mode : utilise g_FlyEnabled déclaré plus haut (ligne 242).
// Quand actif, on bloque la chute (vy clampé à >= 0) pour pouvoir flotter
// / monter en sautant. Désactive aussi la multiplication de vitesse en l'air.

// Détecte si le ped est au sol via le field <IsGrounded>k__BackingField à
// l'offset +0x188 du CharacterActor (Lightbug). Lecture directe en mémoire :
// fiable car mis à jour par Lightbug chaque frame avant set_Velocity.
//   - grounded=true  : le ped touche un sol → speed mult OK
//   - grounded=false : ped en chute/saut → PAS de multiplication (sinon
//                       propulsion latérale à travers la map)
static inline bool isCharacterGrounded(void *self) {
  if (!self) return true; // safe default = pas de mult
  return *((uint8_t*)self + 0x188) != 0;
}

static void hook_SetVelocity(void *self, float x, float y, float z) {
  bool grounded = isCharacterGrounded(self);

  // Fly mode : on bloque la chute (vy ne peut pas être négatif). Le saut
  // (vy positif) reste autorisé → utilisateur saute pour monter.
  // Filtre sur le LOCAL uniquement pour ne pas faire flotter les autres.
  // V158 : On active aussi ce bloc pendant l'Auto-Follow pour éviter de tomber
  // si la cible est temporairement perdue (on reste stationnaire en l'air).
  if ((g_FlyEnabled || Esp_IsAutoFollowActive()) && Esp_IsLocalActor(self) && y < 0.0f) {
    y = 0.0f;
  }

  // Speed mult : seulement au sol. Évite le bug bordure/saut → catapulte.
  if (g_SuperSpeedEnabled && grounded) {
    if (g_SpeedLogCount < 5) {
      LOGI(DBG ": set_Velocity[%d] in=(%.2f,%.2f,%.2f) mult=%.1f grounded=1",
           g_SpeedLogCount, x, y, z, g_SpeedMultiplier);
      g_SpeedLogCount++;
    }
    x *= g_SpeedMultiplier;
    z *= g_SpeedMultiplier;
  } else if (!g_SuperSpeedEnabled) {
    g_SpeedLogCount = 0;
  }
  orig_SetVelocity(self, x, y, z);
}

// 1ter) Idem sur set_PlanarVelocity @ 0x31CA99C en backup. Certains chemins
// Lightbug (Unstable state, glissades) appellent set_PlanarVelocity directement
// sans passer par set_Velocity. On hook les deux pour couvrir tous les cas.
typedef void (*SetPlanarVelocity_t)(void *self, float x, float y, float z);
static SetPlanarVelocity_t orig_SetPlanarVelocity = nullptr;
static void hook_SetPlanarVelocity(void *self, float x, float y, float z) {
  // Speed mult seulement au sol (lecture directe du field IsGrounded).
  if (g_SuperSpeedEnabled && isCharacterGrounded(self)) {
    x *= g_SpeedMultiplier;
    z *= g_SpeedMultiplier;
  }
  orig_SetPlanarVelocity(self, x, y, z);
}

// ============================================================================
// HOOK Camera.set_fieldOfView @ 0x42AA700
// Quand g_CameraFovEnabled=true, force la valeur à g_CameraFov (override Unity).
// Sinon laisse passer normalement.
// ARM64 ABI : self dans X0, value (float) dans S0.
// ============================================================================
typedef void (*SetFieldOfView_t)(void* self, float value);
static SetFieldOfView_t orig_SetFieldOfView = nullptr;
static void hook_SetFieldOfView(void* self, float value) {
  if (g_CameraFovEnabled) {
    value = g_CameraFov;
  }
  orig_SetFieldOfView(self, value);
}

// ============================================================================
// HOOK Transform.set_localScale_Injected @ 0x43070B4
// Quand g_PlayerScaleEnabled=true ET self == local actor's Transform,
// multiplie l'échelle par g_PlayerScale.
//
// V162 FIX : avant on multipliait TOUS les Transforms du jeu (UI, environnement,
// autres peds, véhicules…) ce qui rendait le menu inutilisable dès qu'on
// activait Taille X. Maintenant on compare `self` au Transform du local actor
// (caché par Esp_GetLocalTransform()) → SEUL le local change de taille.
//
// ARM64 ABI : self dans X0, value pointer dans X1.
// ============================================================================
struct Vec3Ref { float x, y, z; };
typedef void (*SetLocalScaleInjected_t)(void* self, Vec3Ref* value);
static SetLocalScaleInjected_t orig_SetLocalScaleInjected = nullptr;
static void hook_SetLocalScaleInjected(void* self, Vec3Ref* value) {
  // Filtre : si on n'a pas encore identifié le local OU si self n'est pas
  // son Transform, on passe la valeur d'origine sans modif (= comportement
  // natif Unity). Coupséquence : tant que l'utilisateur n'a pas ouvert l'ESP
  // au moins 1 fois, le scaling ne s'applique pas → évite de casser l'UI au
  // boot. Dès que le local est identifié (lors du 1er FrameTick ou via le
  // hook PreSimulationUpdate), le scaling fonctionne.
  if (g_PlayerScaleEnabled && value && g_PlayerScale != 1.0f) {
    void* localTr = Esp_GetLocalTransform();
    if (localTr && self == localTr) {
      Vec3Ref scaled = { value->x * g_PlayerScale,
                         value->y * g_PlayerScale,
                         value->z * g_PlayerScale };
      orig_SetLocalScaleInjected(self, &scaled);
      return;
    }
  }
  orig_SetLocalScaleInjected(self, value);
}

// ============================================================================
// DEVICE ID FAKER + WIPE APP DATA (toggle 153 + bouton 154)
// ----------------------------------------------------------------------------
// STRATÉGIE COMPLÈTE pour bypass un ban OneState :
//
// 1) WIPE APP DATA au prochain démarrage : on simule une "fresh install" en
//    supprimant tous les fichiers persistants du jeu :
//    - shared_prefs/  → tokens Firebase, SharedPreferences custom
//    - files/         → PlayerPrefs Unity (UUID applicatif stocké), caches
//    - databases/     → SQLite Firebase Installations IID
//    - cache/         → divers caches d'analytics
//    Ces fichiers contiennent des UUID applicatifs persistants qu'utilise
//    OneState pour t'identifier MÊME si tu changes le device ID Unity.
//    Wiper = nouveau Firebase IID, nouveau PlayerPrefs, nouveau "first launch".
//
// 2) Hook UnityEngine.SystemInfo.* pour faker tout le fingerprint Unity :
//    - get_deviceUniqueIdentifier (le principal)
//    - get_deviceModel / get_deviceName (signature secondaire)
//
// 3) Le toggle 153 écrit un FLAG-FILE persistant `wipe_pending` dans
//    /data/data/<pkg>/cache/. Le wipe ne s'exécute PAS immédiatement (ça
//    crasherait Unity en cours de run) mais au PROCHAIN démarrage du jeu :
//    `wipeAppDataIfFlagged()` est appelée tout au début de hack_thread,
//    AVANT que Unity finisse d'init PlayerPrefs.
//
// 4) Le hook get_deviceUniqueIdentifier reste actif pendant toute la session
//    pour que les calls runtime à l'identifiant retournent le fake.
// ============================================================================
static bool g_DeviceIdFaker = false;
static char g_FakeDeviceId[64] = "";
// Buffer permettant aux hooks SystemInfo.get_deviceModel/Name de retourner
// une valeur fake stable (généré au démarrage si toggle ON).
static char g_FakeDeviceModel[64] = "";
static char g_FakeDeviceName[64]  = "";

// Récupère le dossier /data/data/<pkg>/ via /proc/self/cmdline + format Android.
// Retourne la longueur écrite (sans NUL), 0 si erreur.
static size_t getMyAppDataDir(char* out, size_t outSize) {
  if (outSize < 32) return 0;
  // Lire le package depuis /proc/self/cmdline (premier zero-terminated string).
  FILE* f = fopen("/proc/self/cmdline", "rb");
  if (!f) return 0;
  char pkg[256] = {0};
  size_t r = fread(pkg, 1, sizeof(pkg) - 1, f);
  fclose(f);
  if (r == 0) return 0;
  pkg[sizeof(pkg) - 1] = 0;
  // Coupe au premier ':' s'il y en a un (process privé Android).
  for (size_t i = 0; i < r; i++) if (pkg[i] == ':') { pkg[i] = 0; break; }
  if (!pkg[0]) return 0;
  int n = snprintf(out, outSize, "/data/data/%s", pkg);
  return (n > 0 && (size_t)n < outSize) ? (size_t)n : 0;
}

// Supprime récursivement tout le contenu de `path` (incluant les sous-dirs)
// SANS supprimer `path` lui-même. Utilise nftw() = portable, robuste, single-thread.
#include <ftw.h>
#include <errno.h>
#include <sys/stat.h>
static int rmCallback(const char* fpath, const struct stat* /*sb*/,
                      int typeflag, struct FTW* ftwbuf) {
  if (ftwbuf->level == 0) return 0; // skip the root itself
  if (typeflag == FTW_DP || typeflag == FTW_D) {
    rmdir(fpath);
  } else {
    unlink(fpath);
  }
  return 0;
}
static void wipeDirContents(const char* path) {
  // depth-first, follow no symlinks. nopenfd=16 (sufficient for typical app data).
  nftw(path, rmCallback, 16, FTW_DEPTH | FTW_PHYS);
}

// Path du flag-file qui survit aux redémarrages (cache/).
static void getWipeFlagPath(char* out, size_t outSize) {
  char dataDir[256];
  size_t l = getMyAppDataDir(dataDir, sizeof(dataDir));
  if (!l) { out[0] = 0; return; }
  snprintf(out, outSize, "%s/cache/wipe_pending", dataDir);
}

// Ecrit le flag : au prochain démarrage on wipe.
static void scheduleWipeNextBoot() {
  char path[512]; getWipeFlagPath(path, sizeof(path));
  if (!path[0]) { LOGI(DBG ": scheduleWipe: dataDir introuvable"); return; }
  // S'assure que le dossier cache/ existe.
  char cacheDir[512]; size_t pl = strlen(path);
  // path = .../cache/wipe_pending → cacheDir = path sans "/wipe_pending"
  if (pl > 14) {
    size_t cl = pl - 14;
    if (cl < sizeof(cacheDir)) {
      memcpy(cacheDir, path, cl); cacheDir[cl] = 0;
      mkdir(cacheDir, 0700);
    }
  }
  FILE* f = fopen(path, "wb");
  if (f) { fwrite("1", 1, 1, f); fclose(f); LOGI(DBG ": Wipe scheduled at %s", path); }
  else   { LOGI(DBG ": Wipe schedule FAILED at %s (errno=%d)", path, errno); }
}

// Appelée tout début de hack_thread : si flag présent, wipe shared_prefs/,
// files/, databases/. On NE wipe PAS lib/ (où se trouve notre lib mod).
// Puis supprime le flag pour ne pas wiper deux fois.
static void wipeAppDataIfFlagged() {
  char flag[512]; getWipeFlagPath(flag, sizeof(flag));
  if (!flag[0]) return;
  struct stat st;
  if (stat(flag, &st) != 0) return; // pas de flag = rien à faire
  LOGI(DBG ": *** WIPE FLAG DETECTED — simulating fresh install ***");
  char dataDir[256];
  if (!getMyAppDataDir(dataDir, sizeof(dataDir))) return;
  // Liste des sous-dossiers à wiper. Tout ce qui contient des IDs persistants
  // applicatifs : PlayerPrefs (files/), tokens Firebase (databases/, shared_prefs/),
  // caches divers d'analytics (cache/, no_backup/, app_*).
  const char* subdirs[] = {
    "/files", "/shared_prefs", "/databases", "/cache", "/no_backup",
    "/app_textures", "/app_webview", "/code_cache",
  };
  for (size_t i = 0; i < sizeof(subdirs)/sizeof(subdirs[0]); i++) {
    char p[512]; snprintf(p, sizeof(p), "%s%s", dataDir, subdirs[i]);
    LOGI(DBG ": wiping %s ...", p);
    wipeDirContents(p);
  }
  unlink(flag); // consomme le flag → un wipe = un démarrage
  LOGI(DBG ": *** WIPE COMPLETE — game will see this as a brand new install ***");
}

// Génère un GUID style "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" en hex random.
// Stocké dans g_FakeDeviceId. Appelée au boot et chaque fois que l'utilisateur
// clique le bouton "Régénérer Device ID".
static void regenerateFakeDeviceId() {
  static const char* hex = "0123456789abcdef";
  // Seed PRNG avec time + adresse stack + clock_gettime pour entropie.
  struct timespec ts; clock_gettime(CLOCK_MONOTONIC, &ts);
  uint64_t seed = (uint64_t)time(nullptr) ^ (uint64_t)(uintptr_t)&seed ^
                  (uint64_t)ts.tv_nsec ^ ((uint64_t)ts.tv_sec << 32);
  uint64_t s = seed;
  auto rnd = [&]() {
    // xorshift64
    s ^= s << 13; s ^= s >> 7; s ^= s << 17;
    return (uint32_t)s;
  };
  const int groups[] = {8, 4, 4, 4, 12};
  int idx = 0;
  for (int g = 0; g < 5; g++) {
    for (int k = 0; k < groups[g]; k++) {
      g_FakeDeviceId[idx++] = hex[rnd() & 0xF];
    }
    if (g < 4) g_FakeDeviceId[idx++] = '-';
  }
  g_FakeDeviceId[idx] = 0;
  // Génère aussi un model et un name plausibles. On pioche dans une liste
  // de devices Android réels pour que le fingerprint ait l'air crédible.
  static const char* models[] = {
    "SM-G998B", "SM-S908E", "Pixel 7 Pro", "Pixel 6", "ONEPLUS A6013",
    "M2102J20SG", "Mi 11", "RMX3371", "CPH2451", "SM-A536E",
    "SM-G991B", "Pixel 8", "23021RAA2Y", "2201116SG", "SM-A546E",
  };
  uint32_t mi = rnd() % (uint32_t)(sizeof(models)/sizeof(models[0]));
  snprintf(g_FakeDeviceModel, sizeof(g_FakeDeviceModel), "%s", models[mi]);
  // Name = "Phone-XXXX" avec random suffix pour unicité.
  snprintf(g_FakeDeviceName, sizeof(g_FakeDeviceName),
           "Phone-%04X", (unsigned)(rnd() & 0xFFFF));
  LOGI(DBG ": Device fake -> id='%s' model='%s' name='%s'",
       g_FakeDeviceId, g_FakeDeviceModel, g_FakeDeviceName);
}

typedef void* (*GetDeviceUniqueIdentifier_t)();
static GetDeviceUniqueIdentifier_t orig_GetDeviceUniqueIdentifier = nullptr;
static void* hook_GetDeviceUniqueIdentifier() {
  if (g_DeviceIdFaker && g_FakeDeviceId[0] != 0) {
    void* fake = Esp_MakeIl2cppString(g_FakeDeviceId);
    if (fake) return fake;
  }
  return orig_GetDeviceUniqueIdentifier();
}

// SystemInfo.get_deviceModel @ 0x4249904
typedef void* (*GetDeviceModel_t)();
static GetDeviceModel_t orig_GetDeviceModel = nullptr;
static void* hook_GetDeviceModel() {
  if (g_DeviceIdFaker && g_FakeDeviceModel[0] != 0) {
    void* fake = Esp_MakeIl2cppString(g_FakeDeviceModel);
    if (fake) return fake;
  }
  return orig_GetDeviceModel();
}

// SystemInfo.get_deviceName @ 0x42498B4
typedef void* (*GetDeviceName_t)();
static GetDeviceName_t orig_GetDeviceName = nullptr;
static void* hook_GetDeviceName() {
  if (g_DeviceIdFaker && g_FakeDeviceName[0] != 0) {
    void* fake = Esp_MakeIl2cppString(g_FakeDeviceName);
    if (fake) return fake;
  }
  return orig_GetDeviceName();
}

// 2) ColliderComponent3D.InternalHitFilter(self, raycastHit) @ 0x31AD9BC
// Filtre appele pour CHAQUE hit detecte par Lightbug dans CastBody.
// En NoClip on ignore SEULEMENT les murs (normales horizontales) et on
// CONSERVE les hits sur sol/pentes/escaliers (normales verticales). Comme ça
// le perso traverse les murs mais ne tombe pas à travers le sol quand il y a
// une montée. Threshold normal.y > 0.5 ≈ pentes jusqu'à 60° (escaliers OK).
//
// Layout Unity RaycastHit (struct value) en ARM64 IL2CPP :
//  +0x00 : Vector3 m_Point  (x,y,z)
//  +0x0C : Vector3 m_Normal (x,y,z)   -> normal.y est à +0x10
//  +0x18 : uint   m_FaceID
//  +0x1C : Vector2 m_UV
//  +0x24 : float  m_Distance
typedef bool (*InternalHitFilter_t)(void *self, void *raycastHit);
static InternalHitFilter_t orig_InternalHitFilter = nullptr;
static bool hook_InternalHitFilter(void *self, void *raycastHit) {
  if ((g_NoClipEnabled || Esp_IsAutoFollowActive()) && raycastHit) {
    // Lecture safe de normal.y. Si la struct était minuscule et passée par
    // registre, raycastHit pourrait être nul ou pointer ailleurs ; dans ce
    // cas on retombe sur l'ancien comportement (traverse tout).
    float ny = *(float *)((char *)raycastHit + 0x10);
    // Sol ou pente raisonnable -> on GARDE la collision (perso reste debout).
    // Sauf si on est en auto-follow (on veut tout traverser pour ne pas être bloqué en vol).
    if (ny > 0.5f && !Esp_IsAutoFollowActive()) {
      return orig_InternalHitFilter(self, raycastHit);
    }
    // Mur, plafond ou sol (en follow) -> on IGNORE (perso traverse).
    return false;
  }
  return orig_InternalHitFilter(self, raycastHit);
}

void *hack_thread(void *) {
  LOGI(DBG ": V140 DEVELOPER start");
  // *** ÉTAPE 0 — WIPE APP DATA si flag posé au précédent run ***
  // Doit s'exécuter AVANT que Unity termine de charger PlayerPrefs / Firebase.
  // En pratique on est dans le thread qui démarre dès JNI_OnLoad ; Unity n'a
  // pas encore atteint Awake() de la 1ère scène = aucun fichier n'est encore
  // ouvert. Wipe = sûr.
  wipeAppDataIfFlagged();

  // *** ÉTAPE 0.5 — VERROU HWID (serveur licence) ***
  // Si l'appareil n'est pas autorisé : exit(0). Sinon on continue.
  Hwid_LicenseCheckOrDie();

  if (!wait_for_lib(targetLibName, 60))
    return nullptr;

  LOGI(OBFUSCATE("libil2cpp.so loaded, injecting OneState logic..."));
  void* handleEsVip = dlopen(OBFUSCATE("libEsVip.so"), RTLD_NOW);
  if (handleEsVip) {
      LOGI(OBFUSCATE("Successfully loaded libEsVip.so"));
  } else {
      LOGE(OBFUSCATE("Failed to load libEsVip.so: %s"), dlerror());
  }

  void* handleChungus = dlopen(OBFUSCATE("libchungus.so"), RTLD_NOW);
  if (handleChungus) {
      LOGI(OBFUSCATE("Successfully loaded libchungus.so"));
  } else {
      LOGE(OBFUSCATE("Failed to load libchungus.so: %s"), dlerror());
  }
  // ... (rest of the code remains the same)
  sleep(3);
  LibInfo lib = get_lib_info(targetLibName);
  if (!lib.valid) {
    LOGE(DBG ": FAIL base");
    return nullptr;
  }
  uintptr_t B = lib.image_base;
  g_base = B;
  LOGI(DBG ": base=0x%lx", B);
  ESP_SetBaseAddress(B);

  const char *RET = "C0035FD6";
  const char *RET0 = "00008052C0035FD6"; // MOV W0,#0; RET
  const char *RET1 = "20008052C0035FD6"; // MOV W0,#1; RET
  const char *RET2 = "40008052C0035FD6"; // MOV W0,#2; RET
  const char *RET6 = "C0008052C0035FD6"; // MOV W0,#6; RET (AdminLevel4)

  // --- GOD MODE ---
  patch_HealthSync = MemoryPatch::createWithHex(B + 0x263BBD8, RET);
  patch_Knockout1 = MemoryPatch::createWithHex(B + 0x2EB64A4, RET);
  patch_Knockout2 = MemoryPatch::createWithHex(B + 0x2EE8844, RET);
  // V162 AUDIT REMOVED: 0x2206694 = Animancer.Examples.GameKit.FlinchState.OnDamageReceived (sample code Animancer, jamais executé). Le vrai OnDamageReceived du jeu reste à identifier.
  // patch_Damage = MemoryPatch::createWithHex(B + 0x0x22C9B84, RET);
  patch_KoState = MemoryPatch::createWithHex(B + 0x0x22C9B84, RET0);
  patch_NotKo = MemoryPatch::createWithHex(B + 0x0x22C9B84, RET1);
  patch_IsAlive1 = MemoryPatch::createWithHex(B + 0x0x22C9B84, RET1);
  // V162 AUDIT REMOVED: 0x38BC220 = System.WeakReference.get_IsAlive (DANGEREUX : force GC à reporter tous les objets comme vivants → fuites mémoire). IsAlive du player reste couvert par patch_IsAlive1.
  // patch_IsAlive2 = MemoryPatch::createWithHex(B + 0x0x2D648B4, RET1);
  patch_IsAlive3 = MemoryPatch::createWithHex(B + 0x0x2D648B4, RET1);
  patch_DeadSync = MemoryPatch::createWithHex(B + 0x0x22C9B84, RET);
  patch_ProcessDead = MemoryPatch::createWithHex(B + 0x0x2D648B4, RET);
  patch_DeathUI1 = MemoryPatch::createWithHex(B + 0x0x2D648B4, RET);
  patch_DeathUI2 = MemoryPatch::createWithHex(B + 0x0x2D648B4, RET);
  patch_DeathUI3 = MemoryPatch::createWithHex(B + 0x0x2D648B4, RET);
  // V154 — God Mode v2 (anim KO + état unconscious + cleanup melee)
  patch_UnconsciousDetect    = MemoryPatch::createWithHex(B + 0x0x3006634, RET);
  patch_MeleeKnockoutCleanup = MemoryPatch::createWithHex(B + 0x0x31A1210, RET);
  patch_DeadKnockoutRestore  = MemoryPatch::createWithHex(B + 0x0x30025C0, RET);
  // patch_PedKill et patch_GhostBullet (=WeaponAttackReceive) sont créés plus bas
  // dans la section GHOST MODE et déjà togglés dans case 13.

  // --- STAMINA ---
  patch_StaminaLose = MemoryPatch::createWithHex(B + 0x2EBC2F0, RET);
  patch_StaminaRestore = MemoryPatch::createWithHex(B + 0x2EBC3CC, RET);
  patch_CanSprint = MemoryPatch::createWithHex(B + 0x2ECBC88, RET);

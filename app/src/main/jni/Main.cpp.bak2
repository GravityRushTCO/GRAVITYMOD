// ============================================================================
// THREADS D'AUTOMATISATION (TP 10s, Farm Money, Auto Work)
// ----------------------------------------------------------------------------
// Chaque thread tourne en arrière-plan et exécute l'action périodiquement
// quand son flag global est activé. Les threads sont créés au boot et restent
// en vie pour toute la durée de l'app. Quand le flag est OFF, le thread sleep
// et ne fait rien.
// ============================================================================
#include <thread>
#include <chrono>

static void thread_TpEnemy10s() {
  while (true) {
    if (g_TpEnemy10sEnabled) {
      float tx = 0, ty = 0, tz = 0;
      if (Esp_GetBestTargetWorld(&tx, &ty, &tz)) {
        Teleport_ToPosition(tx, ty + 1.5f, tz);
        LOGI(DBG ": ⏱ TP Enemy 10s → (%.1f, %.1f, %.1f)", tx, ty, tz);
      }
      std::this_thread::sleep_for(std::chrono::seconds(10));
    } else {
      std::this_thread::sleep_for(std::chrono::seconds(1));
    }
  }
}

// Farm Money et Auto Work : ces fonctions reposaient à l'origine sur des TPs
// répétitifs qui ne marchaient pas vraiment. La vraie méthode (Malvado-style)
// est d'activer patch_AutoCheckpoint via le toggle 237 → tous les checkpoints
// de mission/job/event sont considérés "atteints" automatiquement.
//
// Les flags g_FarmMoneyEnabled / g_AutoWorkEnabled / g_StealArmyMaterialsEnabled
// activent ce même patch (mécanisme partagé).
// FIX V161 : `MemoryPatch::Modify()` est un TOGGLE (apply ↔ restore), pas un
// "ensure applied". Appeler Modify() toutes les 2s faisait flicker le patch
// → AutoCheckpoint ne marchait quasi pas. Désormais on applique UNE FOIS à
// l'activation, et on restore quand tous les flags repassent à OFF.
static void thread_AutoMissionProgress() {
  bool patchApplied = false;
  while (true) {
    bool anyActive = g_FarmMoneyEnabled || g_AutoWorkEnabled
                  || g_StealArmyMaterialsEnabled;
    if (anyActive && b_PatchesReady) {
      if (!patchApplied && patch_AutoCheckpoint.isValid()) {
        patch_AutoCheckpoint.Modify();   // apply (passage OFF→ON)
        patchApplied = true;
        LOGI(DBG ": 🎯 AutoCheckpoint APPLIED (auto via FarmMoney/AutoWork/StealArmy)");
      }
    } else if (patchApplied) {
      if (patch_AutoCheckpoint.isValid()) {
        patch_AutoCheckpoint.Restore();  // restore (passage ON→OFF)
      }
      patchApplied = false;
      LOGI(DBG ": 🎯 AutoCheckpoint RESTORED (tous flags OFF)");
    }
    std::this_thread::sleep_for(std::chrono::seconds(1));
  }
}

static void thread_MeuDestino() {
  // Auto-TP au slot 0 toutes les 5 secondes
  while (true) {
    if (g_MeuDestinoEnabled) {
      Teleport_GoSlot(0);
      std::this_thread::sleep_for(std::chrono::seconds(5));
    } else {
      std::this_thread::sleep_for(std::chrono::seconds(1));
    }
  }
}

// V162.1 : Player Scale en mode DIRECT (sans hook).
// Le hook sur Transform.set_localScale_Injected était appelé 1000+ fois/frame
// pour TOUS les Transforms du jeu → SIGSEGV. Nouvelle stratégie : un thread
// bg réapplique la scale UNIQUEMENT sur le Transform du local, toutes les
// 500ms (assez fréquent pour résister aux respawns/anim, mais zéro overhead
// par frame). Le set_localScale_Injected est résolu lazy à la première
// application.
typedef void (*Transform_set_localScale_Injected_t)(void* self, float* value);
static Transform_set_localScale_Injected_t fn_set_localScale = nullptr;
static float g_LastAppliedScale = 1.0f;

static void thread_PlayerScale() {
  while (true) {
    if (g_PlayerScaleEnabled && fabsf(g_PlayerScale - 1.0f) > 0.01f) {
      void* tr = Esp_GetLocalTransform();
      if (tr) {
        if (!fn_set_localScale) {
          fn_set_localScale = (Transform_set_localScale_Injected_t)(g_base + 0x43070B4);
        }
        if (fn_set_localScale) {
          float v[3] = { g_PlayerScale, g_PlayerScale, g_PlayerScale };
          fn_set_localScale(tr, v);
          g_LastAppliedScale = g_PlayerScale;
        }
      }
    } else if (fabsf(g_LastAppliedScale - 1.0f) > 0.01f) {
      // Restore : revient à scale 1 quand l'utilisateur désactive.
      void* tr = Esp_GetLocalTransform();
      if (tr && fn_set_localScale) {
        float v[3] = { 1.0f, 1.0f, 1.0f };
        fn_set_localScale(tr, v);
        g_LastAppliedScale = 1.0f;
      }
    }
    std::this_thread::sleep_for(std::chrono::milliseconds(500));
  }
}

static void startAutomationThreads() {
  static bool started = false;
  if (started) return;
  started = true;
  std::thread(thread_TpEnemy10s).detach();
  std::thread(thread_AutoMissionProgress).detach();
  std::thread(thread_MeuDestino).detach();
  std::thread(thread_PlayerScale).detach();
  LOGI(DBG ": Automation threads started (TpEnemy10s, AutoMissionProgress, MeuDestino, PlayerScale)");
}



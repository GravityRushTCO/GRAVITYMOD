// Real Teleport_ToPosition implementation
bool Teleport_ToPosition(float x, float y, float z, bool ignoreCooldown) {
  resolveLazy();
  resolveTeleport();
  void *actor = s_localActor;
  if (!actor) {
    E_LOGI("Teleport_ToPosition: s_localActor is null, cannot teleport");
    return false;
  }
  V3 pos = {x, y, z};

  // Get the transform and root
  void *actorTr = nullptr;
  if (fn_get_transform)
    actorTr = fn_get_transform(actor);

  void *rootTr = actorTr;
  if (actorTr && fn_get_root) {
    rootTr = fn_get_root(actorTr);
  }

  if (rootTr && rootTr != actorTr) {
    Esp_DirectVehicleTP(rootTr, x, y, z, true);
    E_LOGI(
        "Teleport_ToPosition: Esp_DirectVehicleTP called for vehicle root=%p",
        rootTr);
  } else {
    extern bool g_NoClipEnabled;
    if (g_NoClipEnabled || Esp_IsAutoFollowActive()) {
      Esp_DirectVehicleTP(rootTr, x, y, z, false);
      E_LOGI("Teleport_ToPosition: Player TP via DirectTransform "
             "(AutoFollow/NoClip) OK");
    } else {
      // Map TP or Slot TP on foot: move transform directly first to bypass
      // obstacles, then call SweepAndTeleport to update the character
      // controller's internal position.
      Esp_DirectVehicleTP(rootTr, x, y, z, false);
      if (fn_sweep_tp) {
        fn_sweep_tp(actor, x, y, z);
      }
      E_LOGI("Teleport_ToPosition: Player TP via Direct + Sweep OK");
    }
  }

  return true;
}

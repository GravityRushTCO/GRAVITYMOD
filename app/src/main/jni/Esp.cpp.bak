extern "C" void Esp_TPCarToTarget() {
  float tx = 0, ty = 0, tz = 0;
  if (Esp_GetBestTargetWorld(&tx, &ty, &tz)) {
    pthread_mutex_lock(&s_mtx);
    void *actor = s_localActor;
    pthread_mutex_unlock(&s_mtx);

    if (!actor) {
      E_LOGI("Esp_TPCarToTarget: s_localActor is null");
      return;
    }

    void *actorTr = nullptr;
    if (fn_get_transform)
      actorTr = fn_get_transform(actor);

    void *rootTr = actorTr;
    if (actorTr && fn_get_root) {
      rootTr = fn_get_root(actorTr);
    }

    if (rootTr && rootTr != actorTr) {
      // Player is in a vehicle - teleport the vehicle
      Esp_DirectVehicleTP(rootTr, tx, ty + 1.5f, tz, false);
      E_LOGI("Esp_TPCarToTarget: Vehicle TP to target (%.1f, %.1f, %.1f)", tx, ty, tz);
    } else {
      // Player is not in a vehicle - teleport the player
      bool ok = Teleport_ToPosition(tx, ty + 1.5f, tz, false);
      E_LOGI("Esp_TPCarToTarget: Player TP to target (%.1f, %.1f, %.1f) ok=%d", tx, ty, tz, (int)ok);
    }
  } else {
    E_LOGI("Esp_TPCarToTarget: No target found");
  }
}
}
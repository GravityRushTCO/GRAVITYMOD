// Static constants
const float VipMenu::NOTCH_W = 28.f;
const float VipMenu::NOTCH_H = 80.f;

void VipMenu::init() {
  // Initializer
}

bool VipMenu::onTouch(int action, float x, float y) {
  m_tx = x;
  m_ty = y;

  float sw = (float)g_GL.W();
  float sh = (float)g_GL.H();

  // Compute the panel X position from animation (slides in from left)
  float panelX = -m_w + m_w * easeInOutCubic(m_openAnim);
  // Notch is always visible at the right edge of the panel
  float notchX = panelX + m_w;
  float notchY = (sh - NOTCH_H) / 2.f;

  if (!m_open) {
    // Tap on notch opens the menu
    if (action == 0) {
      if (x >= notchX && x <= notchX + NOTCH_W && y >= notchY && y <= notchY + NOTCH_H) {
        m_open = true;
        m_openPhase = 0.f;
        return true;
      }
    }
    return false;
  }

  // Menu is open
  // Tap on notch closes the menu
  if (action == 0 && x >= notchX && x <= notchX + NOTCH_W && y >= notchY && y <= notchY + NOTCH_H) {
    m_open = false;
    return true;
  }
  // Tap outside panel closes the menu
  if (action == 0 && x > panelX + m_w + NOTCH_W) {
    m_open = false;
    return true;
  }

  if (action == 0) { // DOWN
    m_touchDown = true;
    m_click = true;
    m_isScrolling = false;
    m_lastTy = y;
  } else if (action == 1) { // UP
    m_touchDown = false;
    if (m_isScrolling) m_click = false;
    m_isScrolling = false;
  } else if (action == 2) { // MOVE
    if (m_touchDown) {
      float dy = y - m_lastTy;
      if (fabsf(dy) > 5.f) m_isScrolling = true;
      // Content area starts after header (120px) and tabs (50px)
      float contentTop = m_y + 170.f;
      if (m_isScrolling && m_tx >= panelX && m_tx <= panelX + m_w &&
          m_ty > contentTop && m_ty < sh) {
        m_scrollY[m_tab] += dy;
        if (m_scrollY[m_tab] > 0) m_scrollY[m_tab] = 0;
      }
    }
    m_lastTy = y;
  }

  if (m_isScrolling) return true;
  if (x >= panelX && x <= panelX + m_w) return true;
  return false;
}

void VipMenu::initBgStars() {
  for (int i = 0; i < 60; i++) {
    m_bgStars[i].x = m_x + (rand() % (int)m_w);
    m_bgStars[i].y = m_y + (rand() % (int)m_h);
    m_bgStars[i].vx = ((rand() % 100) / 100.f - 0.5f) * 0.5f;
    m_bgStars[i].vy = ((rand() % 100) / 100.f + 0.1f) * 1.5f;
    m_bgStars[i].size = (rand() % 100) / 100.f * 2.f + 1.f;
    m_bgStars[i].life =
        (rand() % 100) / 100.f * M_PI * 2.f; // Used for twinkle phase

    int ct = rand() % 3;
    if (ct == 0) {
      m_bgStars[i].r = 0.4f;
      m_bgStars[i].g = 0.8f;
      m_bgStars[i].b = 1.f;
    } else if (ct == 1) {
      m_bgStars[i].r = 0.8f;
      m_bgStars[i].g = 0.4f;
      m_bgStars[i].b = 1.f;
    } else {
      m_bgStars[i].r = 1.f;
      m_bgStars[i].g = 1.f;
      m_bgStars[i].b = 1.f;
    }
  }
  m_bgStarsInit = true;
}

void VipMenu::updateBgStars() {
  for (int i = 0; i < 60; i++) {
    m_bgStars[i].x += m_bgStars[i].vx;
    m_bgStars[i].y += m_bgStars[i].vy;
    m_bgStars[i].life += 0.05f;

    if (m_bgStars[i].y > m_y + m_h || m_bgStars[i].x < m_x ||
        m_bgStars[i].x > m_x + m_w) {
      m_bgStars[i].x = m_x + (rand() % (int)m_w);
      m_bgStars[i].y = m_y;
    }
  }
}

void VipMenu::drawBgStars() {
  for (int i = 0; i < 60; i++) {
    float twinkle = (sinf(m_bgStars[i].life) + 1.f) * 0.5f;
    GColor col = {m_bgStars[i].r, m_bgStars[i].g, m_bgStars[i].b,
                  0.2f + 0.8f * twinkle};
    g_GL.circleFill(m_bgStars[i].x, m_bgStars[i].y, m_bgStars[i].size,
                    col * m_openAnim);
  }
}

void VipMenu::initOrbs() {
  for (int i = 0; i < 8; i++) {
    m_orbs[i].angle = (M_PI * 2.f / 8.f) * i;
    m_orbs[i].radius = 45.f + (rand() % 15);
    m_orbs[i].speed =
        ((rand() % 100) / 100.f * 0.04f + 0.02f) * (i % 2 == 0 ? 1 : -1);
    m_orbs[i].size = 2.f + (rand() % 3);
    m_orbs[i].r = (rand() % 100) / 100.f;
    m_orbs[i].g = (rand() % 100) / 100.f;
    m_orbs[i].b = 1.f;
  }
  m_orbsInit = true;
}

void VipMenu::drawBubble() {
  m_planetAngle += 0.02f;

  // Real 3D Planet Texture (using our new PNG asset)
  float pSize = 75.f; // Slightly larger for premium look
  if (m_texPlanet) {
    // 4D Glow effect behind the planet
    float pulse = (sinf(m_anim * 3.0f) + 1.f) * 0.5f;
    g_GL.circleFill(m_iconX, m_iconY, pSize * 0.6f + pulse * 10.f, P::CYAN().alpha(0.3f), 32);
    
    // The rotating 3D planet (Using our custom 3D sphere mapper)
    g_GL.sphere3D(m_iconX, m_iconY, pSize / 2.f, m_planetAngle, GColor::hex(0xFFFFFF, 1.0f), m_texPlanet);
    
    // Satellite Orbit Ring 1
    g_GL.arcOutline(m_iconX, m_iconY, pSize * 0.7f, 2.0f, m_anim * 2.f, m_anim * 2.f + M_PI * 1.5f, P::CYAN().alpha(0.8f), 32);
    // Satellite Orbit Ring 2 (Opposite direction)
    g_GL.arcOutline(m_iconX, m_iconY, pSize * 0.85f, 1.5f, -m_anim * 1.5f, -m_anim * 1.5f + M_PI, P::CYAN().alpha(0.5f), 32);
    
    // Satellites (Dots on the rings)
    float sat1X = m_iconX + cosf(m_anim * 2.f) * (pSize * 0.7f);
    float sat1Y = m_iconY + sinf(m_anim * 2.f) * (pSize * 0.7f);
    g_GL.circleFill(sat1X, sat1Y, 4.0f, P::CYAN(), 12);
    
    float sat2X = m_iconX + cosf(-m_anim * 1.5f) * (pSize * 0.85f);
    float sat2Y = m_iconY + sinf(-m_anim * 1.5f) * (pSize * 0.85f);
    g_GL.circleFill(sat2X, sat2Y, 3.0f, P::CYAN().alpha(0.8f), 12);
  } else {
    g_GL.circleFill(m_iconX, m_iconY, 30.f, GColor::hex(0x020205, 1.0f));
  }
}

